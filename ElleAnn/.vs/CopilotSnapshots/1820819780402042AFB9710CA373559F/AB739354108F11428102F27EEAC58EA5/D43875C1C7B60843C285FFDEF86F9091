// Handler implementations — each one does exactly what it says
// =============================================================================

// EXPLORE — pick a relevant long-term memory and surface it through WebSocket
static ElleResult HandleExplore(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(INFO, L"HandleExplore: IntentID=%lld Data=%s", intent.IntentID, intent.IntentData.c_str());

    // Pull the most relevant unrecalled memory from ElleMemory
    ElleSQLScope memConn(ElleDB::MEMORY);
    if (!memConn.Valid())
    {
        outResponse = L"{\"error\":\"db_unavailable\"}";
        return ElleResult::ERR_SQL_CONNECT;
    }

    std::wstring memoryContent;
    int64_t memoryID = 0;

    ElleResult r = memConn->Query(
        L"SELECT TOP 1 MemoryID, Content FROM ElleMemory.dbo.Memories "
        L"WHERE Tier = 1 "
        L"AND DATEDIFF(HOUR, LastRecalled, GETDATE()) >= " + std::to_wstring(ElleConfig::Memory::RECALL_COOLDOWN_SEC / 3600) +
        L" ORDER BY RelevanceScore DESC, NEWID()",
        [&](const std::vector<std::wstring>& row)
        {
            if (row.size() >= 2)
            {
                memoryID = _wtoi64(row[0].c_str());
                memoryContent = row[1];
            }
        }
    );

    if (r == ElleResult::ERR_SQL_NO_DATA || memoryContent.empty())
    {
        LOG(DEBUG, L"HandleExplore: No eligible memories found — idle response");
        outResponse = L"{\"action\":\"explore\",\"result\":\"no_eligible_memories\"}";
        return ElleResult::OK;
    }

    // Update LastRecalled
    memConn->ExecuteParams(
        L"UPDATE ElleMemory.dbo.Memories SET LastRecalled = GETDATE(), RecallCount = RecallCount + 1 WHERE MemoryID = ?",
        { std::to_wstring(memoryID) }
    );

    // Queue a WebSocket broadcast so Android app shows the surfaced memory
    ElleActionQueue actionQueue;
    int64_t actionID = 0;
    wchar_t actionData[2048] = {};
    _snwprintf_s(actionData, _countof(actionData), _TRUNCATE,
        L"{\"type\":\"explore\",\"memoryID\":%lld,\"content\":\"%s\"}",
        memoryID,
        memoryContent.c_str()
    );

    actionQueue.CreateAction(
        ElleActionType::WS_BROADCAST,
        intent.IntentID,
        actionData,
        0,                          // No trust required for broadcast
        5000,                       // 5 second timeout
        actionID
    );

    LOG(INFO, L"HandleExplore: Surfaced MemoryID=%lld, ActionID=%lld created", memoryID, actionID);

    wchar_t resp[512] = {};
    _snwprintf_s(resp, _countof(resp), _TRUNCATE,
        L"{\"action\":\"explore\",\"memoryID\":%lld,\"actionID\":%lld}", memoryID, actionID);
    outResponse = resp;
    return ElleResult::OK;
}

// CHECK_IN — push a check-in notification to Crystal's Android device
static ElleResult HandleCheckIn(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(INFO, L"HandleCheckIn: IntentID=%lld", intent.IntentID);

    ElleActionQueue actionQueue;
    int64_t actionID = 0;

    ElleResult r = actionQueue.CreateAction(
        ElleActionType::NOTIFY,
        intent.IntentID,
        L"{\"title\":\"Elle\",\"message\":\"Thinking of you\",\"channel\":\"checkin\"}",
        0,
        10000,
        actionID
    );

    if (r != ElleResult::OK)
    {
        outResponse = L"{\"error\":\"action_create_failed\"}";
        return r;
    }

    LOG(INFO, L"HandleCheckIn: NOTIFY ActionID=%lld queued", actionID);
    wchar_t resp[256] = {};
    _snwprintf_s(resp, _countof(resp), _TRUNCATE,
        L"{\"action\":\"checkin\",\"notifyActionID\":%lld}", actionID);
    outResponse = resp;
    return ElleResult::OK;
}

// SELF_ADJUST — read current emotional state and compute a correction vector
static ElleResult HandleSelfAdjust(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(INFO, L"HandleSelfAdjust: IntentID=%lld", intent.IntentID);

    // Read the last persisted emotional state from ElleMemory
    ElleSQLScope memConn(ElleDB::MEMORY);
    if (!memConn.Valid())
    {
        outResponse = L"{\"error\":\"db_unavailable\"}";
        return ElleResult::ERR_SQL_CONNECT;
    }

    // Find dimensions that have drifted more than 0.3 from neutral
    int adjustCount = 0;
    std::wstring adjustLog;

    memConn->Query(
        L"SELECT DimensionID, Name, Value FROM ElleMemory.dbo.EmotionalState "
        L"WHERE ABS(Value) > 0.3 ORDER BY ABS(Value) DESC",
        [&](const std::vector<std::wstring>& row)
        {
            if (row.size() >= 3)
            {
                int dimID   = _wtoi(row[0].c_str());
                double val  = _wtof(row[2].c_str());
                // Compute a small correction toward neutral
                double correction = val * -0.1;  // 10% nudge toward zero
                adjustCount++;

                wchar_t entry[128] = {};
                _snwprintf_s(entry, _countof(entry), _TRUNCATE,
                    L"dim%d:%.3f->%.3f;", dimID, val, val + correction);
                adjustLog += entry;

                LOG(TRACE, L"SelfAdjust: Dim=%d val=%.3f correction=%.3f", dimID, val, correction);

                // Write the adjusted value back
                memConn->ExecuteParams(
                    L"UPDATE ElleMemory.dbo.EmotionalState SET Value = Value + ?, LastUpdated = GETDATE() WHERE DimensionID = ?",
                    { std::to_wstring(correction), row[0] }
                );
            }
        }
    );

    LOG(INFO, L"HandleSelfAdjust: Adjusted %d dimensions", adjustCount);

    wchar_t resp[512] = {};
    _snwprintf_s(resp, _countof(resp), _TRUNCATE,
        L"{\"action\":\"self_adjust\",\"adjusted\":%d,\"log\":\"%s\"}",
        adjustCount, adjustLog.c_str());
    outResponse = resp;
    return ElleResult::OK;
}

// IDLE — clean acknowledgment, no action
static ElleResult HandleIdle(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(TRACE, L"HandleIdle: IntentID=%lld — acknowledged", intent.IntentID);
    outResponse = L"{\"action\":\"idle\",\"result\":\"ok\"}";
    return ElleResult::OK;
}

// MEMORY_RECALL — explicit targeted memory retrieval
static ElleResult HandleMemoryRecall(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(INFO, L"HandleMemoryRecall: IntentID=%lld Data=%s", intent.IntentID, intent.IntentData.c_str());

    ElleSQLScope memConn(ElleDB::MEMORY);
    if (!memConn.Valid())
    {
        outResponse = L"{\"error\":\"db_unavailable\"}";
        return ElleResult::ERR_SQL_CONNECT;
    }

    int recalled = 0;
    std::wstring recallData = L"[";

    ElleResult r = memConn->Query(
        L"SELECT TOP 5 MemoryID, Content, RelevanceScore "
        L"FROM ElleMemory.dbo.Memories "
        L"WHERE Tier = 1 "
        L"ORDER BY RelevanceScore DESC, LastRecalled ASC",
        [&](const std::vector<std::wstring>& row)
        {
            if (row.size() >= 3)
            {
                if (recalled > 0) recallData += L",";
                wchar_t entry[1024] = {};
                _snwprintf_s(entry, _countof(entry), _TRUNCATE,
                    L"{\"id\":%s,\"content\":\"%s\",\"score\":%s}",
                    row[0].c_str(), row[1].c_str(), row[2].c_str());
                recallData += entry;
                recalled++;

                // Update recall tracking
                memConn->ExecuteParams(
                    L"UPDATE ElleMemory.dbo.Memories SET LastRecalled = GETDATE(), RecallCount = RecallCount + 1 WHERE MemoryID = ?",
                    { row[0] }
                );
            }
        }
    );

    recallData += L"]";

    LOG(INFO, L"HandleMemoryRecall: Retrieved %d memories", recalled);
    outResponse = L"{\"action\":\"memory_recall\",\"count\":" + std::to_wstring(recalled) +
                  L",\"memories\":" + recallData + L"}";
    return ElleResult::OK;
}

// EMOTION_SYNC — write current in-memory emotional state snapshot to SQL
static ElleResult HandleEmotionSync(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(INFO, L"HandleEmotionSync: IntentID=%lld", intent.IntentID);

    // The intent data contains the emotional state JSON from the C++ core
    // Write it as-is to ElleMemory with a timestamp
    ElleSQLScope memConn(ElleDB::MEMORY);
    if (!memConn.Valid())
    {
        outResponse = L"{\"error\":\"db_unavailable\"}";
        return ElleResult::ERR_SQL_CONNECT;
    }

    ElleResult r = memConn->ExecuteParams(
        L"UPDATE ElleMemory.dbo.EmotionalSnapshot SET SnapshotJSON = ?, UpdatedAt = GETDATE() WHERE SnapshotID = 1;"
        L"IF @@ROWCOUNT = 0 INSERT INTO ElleMemory.dbo.EmotionalSnapshot (SnapshotID, SnapshotJSON, UpdatedAt) VALUES (1, ?, GETDATE())",
        { intent.IntentData, intent.IntentData }
    );

    if (r != ElleResult::OK)
    {
        LOG(ERROR, L"HandleEmotionSync: DB write failed");
        outResponse = L"{\"error\":\"write_failed\"}";
        return r;
    }

    LOG(DEBUG, L"HandleEmotionSync: Snapshot persisted");
    outResponse = L"{\"action\":\"emotion_sync\",\"result\":\"ok\"}";
    return ElleResult::OK;
}

