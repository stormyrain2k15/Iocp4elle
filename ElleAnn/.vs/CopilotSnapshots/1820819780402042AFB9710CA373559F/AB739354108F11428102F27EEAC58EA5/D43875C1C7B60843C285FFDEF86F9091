// HEARTBEAT — update the worker keepalive in ElleSystem
static ElleResult HandleHeartbeat(const ElleIntent& intent, std::wstring& outResponse)
{
    LOG(TRACE, L"HandleHeartbeat: IntentID=%lld", intent.IntentID);

    ElleSQLScope sysConn(ElleDB::SYSTEM);
    if (!sysConn.Valid())
    {
        outResponse = L"{\"error\":\"db_unavailable\"}";
        return ElleResult::ERR_SQL_CONNECT;
    }

    sysConn->ExecuteParams(
        L"UPDATE ElleSystem.dbo.Workers SET LastHeartbeat = GETDATE() WHERE WorkerName = ?",
        { std::wstring(SVCNAME) }
    );

    outResponse = L"{\"action\":\"heartbeat\",\"result\":\"ok\"}";
    return ElleResult::OK;
}

// =============================================================================
// ElleQueueWorkerService — the service class
// =============================================================================
class ElleQueueWorkerService : public ElleServiceBase
{
public:
    ElleQueueWorkerService()
        : ElleServiceBase(SVCNAME)
    {}

protected:
    ElleResult OnStart() override
    {
        LOG(INFO, L"OnStart: Initializing QueueWorker service");

        ElleResult r = InitSharedInfrastructure();
        if (r != ElleResult::OK)
            return r;

        // QueueWorker is the first service. Generate a new epoch for this
        // platform run. All other services adopt this epoch on their OnStart.
        r = ElleEpochManager::Get().Init(true);
        if (r != ElleResult::OK)
        {
            LOG(FATAL, L"EpochManager::Init failed: %s", ElleResultStr(r));
            return r;
        }

        // Reclaim any rows stranded from a prior crashed run before polling starts.
        // This runs before anything else touches the queues.
        int intentsReclaimed = 0, actionsReclaimed = 0;
        ElleEpochManager::Get().ReclaimStranded(intentsReclaimed, actionsReclaimed);
        if (intentsReclaimed > 0 || actionsReclaimed > 0)
            LOG(WARN, L"OnStart: Reclaimed %d stranded intents, %d stranded actions from prior epoch",
                intentsReclaimed, actionsReclaimed);

        // Register all intent handlers
        m_Worker.RegisterIntentHandler(ElleIntentType::EXPLORE,         HandleExplore);
        m_Worker.RegisterIntentHandler(ElleIntentType::CHECK_IN,        HandleCheckIn);
        m_Worker.RegisterIntentHandler(ElleIntentType::SELF_ADJUST,     HandleSelfAdjust);
        m_Worker.RegisterIntentHandler(ElleIntentType::IDLE,            HandleIdle);
        m_Worker.RegisterIntentHandler(ElleIntentType::MEMORY_RECALL,   HandleMemoryRecall);
        m_Worker.RegisterIntentHandler(ElleIntentType::EMOTION_SYNC,    HandleEmotionSync);
        m_Worker.RegisterIntentHandler(ElleIntentType::SEND_NOTIFY,     HandleSendNotify);
        m_Worker.RegisterIntentHandler(ElleIntentType::SEND_MESSAGE,    HandleSendMessage);
        m_Worker.RegisterIntentHandler(ElleIntentType::HEARTBEAT,       HandleHeartbeat);

        LOG(INFO, L"OnStart: All intent handlers registered");

        RegisterWorker();
        }

        r = m_Worker.Start();
        if (r != ElleResult::OK)
        {
            LOG(FATAL, L"OnStart: ElleQueueWorker::Start() failed — %s", ElleResultStr(r));
            return r;
        }

        LOG(INFO, L"OnStart: QueueWorker service running. IntentQueue/ActionQueue loop is active.");
        return ElleResult::OK;
    }

    void OnStop() override
    {
        LOG(INFO, L"OnStop: Stopping QueueWorker service");
        m_Worker.Stop();

        UnregisterWorker();
        ElleSQLScope sysConn(ElleDB::SYSTEM);
        if (sysConn.Valid())
        {
            sysConn->ExecuteParams(
                L"UPDATE ElleSystem.dbo.Workers SET Status = 0, StoppedAt = GETDATE() WHERE WorkerName = ?",
                { std::wstring(SVCNAME) }
            );
        }

        LOG(INFO, L"OnStop: Intents processed=%llu failed=%llu",
            m_Worker.IntentsProcessed(), m_Worker.IntentsFailed());
            m_Worker.ActionsExecuted(), m_Worker.ActionsFailed());

        ShutdownSharedInfrastructure();
    }

private:
    ElleQueueWorker m_Worker;
};

// =============================================================================
// main — handles install/uninstall/console/service modes
// =============================================================================
int wmain(int argc, wchar_t* argv[])
{
    ElleQueueWorkerService svc;

    if (argc >= 2)
    {
        if (_wcsicmp(argv[1], L"install") == 0)
        {
            wchar_t exePath[MAX_PATH] = {};
            GetModuleFileNameW(nullptr, exePath, MAX_PATH);

            ElleResult r = svc.Install(
                L"Elle Queue Worker",
                L"Elle-Ann ESI — IntentQueue/ActionQueue IPC processor. Closes the loop between C++ core and service layer.",
                exePath
            );
            return (r == ElleResult::OK) ? 0 : 1;
        }
        else if (_wcsicmp(argv[1], L"uninstall") == 0)
        {
            ElleResult r = svc.Uninstall();
            return (r == ElleResult::OK) ? 0 : 1;
        }
        else if (_wcsicmp(argv[1], L"console") == 0)
        {
            svc.RunAsConsole();
            return 0;
        }
        else
        {
            wprintf(L"Usage: %s [install | uninstall | console]\n", argv[0]);
            return 1;
        }
    }

    // Double-click (no args) interactive install path
    if (argc == 1 && ElleServiceBase::IsInteractiveSession())
    {
        wchar_t exePath[MAX_PATH] = {};
        GetModuleFileNameW(nullptr, exePath, MAX_PATH);

        ElleResult r = svc.Install(
            L"Elle Queue Worker",
            L"Elle-Ann ESI — IntentQueue/ActionQueue IPC processor. Closes the loop between C++ core and service layer.",
            exePath
        );

        if (r == ElleResult::OK)
            MessageBoxW(nullptr, L"Service uploaded ok", L"Install", MB_OK | MB_ICONINFORMATION);
        else
            MessageBoxW(nullptr, L"Service upload failed", L"Install", MB_OK | MB_ICONERROR);

        return (r == ElleResult::OK) ? 0 : 1;
    }

    // No args — normal SCM launch
    svc.RunAsService();
    return 0;
}
