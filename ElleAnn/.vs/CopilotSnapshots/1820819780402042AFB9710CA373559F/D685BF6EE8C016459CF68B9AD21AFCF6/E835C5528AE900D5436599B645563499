ElleResult ElleIntentQueue::GetPendingIntents(
    std::vector<ElleIntent>& outIntents,
    int maxBatch)
{
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"GetPendingIntents maxBatch=%d", maxBatch);
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    // sp_GetPendingIntents atomically claims up to @MaxBatch intents
    // by setting their status to PROCESSING and returning them.
    std::vector<std::pair<std::wstring, std::wstring>> params =
    {
        { L"@MaxBatch", std::to_wstring(maxBatch) }
    };

    outIntents.clear();
    ElleResult r = conn->ExecProc(L"sp_GetPendingIntents", params);

    if (r == ElleResult::ERR_SQL_NO_DATA)
    {
        wchar_t _elle_log_buf[128] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"No pending intents");
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_QUEUE_EMPTY;
    }

    if (r != ElleResult::OK)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"sp_GetPendingIntents failed: %s", conn->LastError.c_str());
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return r;
    }

    // Re-query to get the claimed rows (proc returns them as a result set)
    // Use plain Query() here — zero rows claimed is a valid outcome (another worker
    // grabbed all pending intents between our proc call and this read). That is not
    // an error; it is normal concurrent operation. ERR_QUEUE_EMPTY is a semantic
    // signal to the poll loop, not an I/O failure.
    int claimedCount = 0;
    r = conn->QueryRows(
        L"SELECT IntentID, TypeID, StatusID, IntentData, Response, "
        L"CreatedAt, UpdatedAt, TrustRequired, Priority "
        L"FROM ElleCore.dbo.IntentQueue "
        L"WHERE StatusID = 1 AND ClaimedByThread = @@SPID "
        L"ORDER BY Priority DESC, CreatedAt ASC",
        [&](const std::vector<std::wstring>& row)
        {
            outIntents.push_back(IntentFromRow(row));
        },
        claimedCount
    );

    if (r == ElleResult::ERR_SQL_NO_DATA)
        r = ElleResult::OK;  // Zero claimed is normal, not an error

    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"GetPendingIntents claimed %zu intents", outIntents.size());
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return outIntents.empty() ? ElleResult::ERR_QUEUE_EMPTY : ElleResult::OK;
}

ElleResult ElleIntentQueue::SubmitIntentResponse(
    int64_t intentID,
    ElleIntentStatus status,
    const std::wstring& responseJson)
{
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"SubmitIntentResponse IntentID=%lld Status=%d", intentID, static_cast<int>(status));
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    // sp_SubmitIntentResponse now SELECTs the updated row back as its last result
    // set so we get both the affected count and the persisted values in one
    // round-trip. No separate verification read needed.
    std::vector<std::pair<std::wstring, std::wstring>> params =
    {
        { L"@IntentID",     std::to_wstring(intentID) },
        { L"@StatusID",     std::to_wstring(static_cast<int>(status)) },
        { L"@Response",     responseJson }
    };

    ElleSQLResult result;
    int verifiedStatus   = -1;
    std::wstring verifiedResponse;
    bool rowReturned     = false;

    ElleResult r = conn->ExecProcStructured(
        L"sp_SubmitIntentResponse",
        params,
        result,
        [&](const std::vector<std::wstring>& row)
        {
            // Row layout from proc: IntentID, StatusID, Response, UpdatedAt
            if (row.size() >= 3)
            {
                verifiedStatus   = _wtoi(row[1].c_str());
                verifiedResponse = row[2];
                rowReturned      = true;
            }
        }
    );

    // Write succeeded check — proc executed and affected rows > 0
    if (r != ElleResult::OK || !result.WriteSucceeded)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"SubmitIntentResponse WRITE FAILED: IntentID=%lld RowsAffected=%d Error=%s",
            intentID, result.RowsAffected, result.ErrorDetail.c_str());
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return (r != ElleResult::OK) ? r : ElleResult::ERR_SQL_QUERY;
    }

    // Write verified check — confirm every field we wrote is what the DB now holds
    if (!rowReturned)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"SubmitIntentResponse WRITE UNVERIFIED: IntentID=%lld — proc returned no row. Write may have committed but persistence cannot be confirmed.", intentID);
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (verifiedStatus != static_cast<int>(status))
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"SubmitIntentResponse WRITE UNVERIFIED: IntentID=%lld StatusID mismatch — wrote %d, DB has %d",
            intentID, static_cast<int>(status), verifiedStatus);
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    // Response field verification: if a non-empty response was written,
    // confirm it landed. Empty responses are not verified (no-op writes).
    if (!responseJson.empty() && verifiedResponse != responseJson)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"SubmitIntentResponse WRITE UNVERIFIED: IntentID=%lld Response mismatch — wrote %zu chars, DB has %zu chars",
            intentID, responseJson.size(), verifiedResponse.size());
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    result.WriteVerified = true;
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"IntentID=%lld write succeeded and verified. status=%d response_len=%zu",
            intentID, verifiedStatus, verifiedResponse.size());
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return ElleResult::OK;
}

ElleResult ElleIntentQueue::MarkIntentStale(int64_t intentID)
{
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Marking IntentID=%lld as STALE", intentID);
        ElleLogger::Get().Write(ElleLogLevel::WARN, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return SubmitIntentResponse(intentID, ElleIntentStatus::STALE, L"{\"reason\":\"timeout\"}");
}

ElleResult ElleIntentQueue::PurgeStaleIntents(int& outPurged)
{
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"PurgeStaleIntents timeout=%d sec", ElleConfig::Queue::INTENT_STALE_TIMEOUT_SEC);
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    outPurged = 0;

    wchar_t sql[512] = {};
    _snwprintf_s(sql, _countof(sql), _TRUNCATE,
        L"UPDATE ElleCore.dbo.IntentQueue "
        L"SET StatusID = %d, UpdatedAt = GETDATE() "
        L"WHERE StatusID IN (%d, %d) "
        L"AND DATEDIFF(SECOND, CreatedAt, GETDATE()) > %d",
        static_cast<int>(ElleIntentStatus::STALE),
        static_cast<int>(ElleIntentStatus::PENDING),
        static_cast<int>(ElleIntentStatus::PROCESSING),
        ElleConfig::Queue::INTENT_STALE_TIMEOUT_SEC
    );

    // Fix: capture @@ROWCOUNT in the same batch as the UPDATE.
    // A separate SELECT @@ROWCOUNT call returns the row count of the SELECT
    // itself (1), not the UPDATE. DECLARE/@affected keeps it in one batch.
    wchar_t batchSql[768] = {};
    _snwprintf_s(batchSql, _countof(batchSql), _TRUNCATE,
        L"DECLARE @affected INT; "
        L"%s; "
        L"SET @affected = @@ROWCOUNT; "
        L"SELECT @affected;",
        sql
    );

    int rowCount = 0;
    ElleResult r = conn->QueryRows(batchSql,
        [&](const std::vector<std::wstring>& row)
        {
            if (!row.empty() && !row[0].empty())
                outPurged = _wtoi(row[0].c_str());
        },
        rowCount
    );

    // QueryRows returns ERR_SQL_NO_DATA if the SELECT returned no rows —
    // that can't happen here (SELECT @affected always returns one row),
    // but treat it as OK with zero purged if it somehow does.
    if (r == ElleResult::ERR_SQL_NO_DATA)
        r = ElleResult::OK;

    if (outPurged > 0)
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Purged %d stale intents", outPurged);
        ElleLogger::Get().Write(ElleLogLevel::WARN, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    return r;
}

ElleResult ElleIntentQueue::GetPendingCount(int& outCount)
{
    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    outCount = 0;
    ElleResult r = conn->Query(
        L"SELECT COUNT(*) FROM ElleCore.dbo.IntentQueue WHERE StatusID = 0",
        [&](const std::vector<std::wstring>& row)
        {
            if (!row.empty())
                outCount = _wtoi(row[0].c_str());
        });

    {
        wchar_t _elle_log_buf[128] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"PendingCount=%d", outCount);
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"IntentQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return r;
}

