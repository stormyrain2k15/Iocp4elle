ElleQueueWorker::ElleQueueWorker()
    : m_Thread(nullptr)
    , m_StopEvent(nullptr)
    , m_Running(false)
    , m_IntentsProcessed(0)
    , m_IntentsFailed(0)
{
}

ElleQueueWorker::~ElleQueueWorker()
{
    Stop();
}

void ElleQueueWorker::RegisterIntentHandler(ElleIntentType type, ElleIntentHandler handler)
{
    std::lock_guard<std::mutex> lock(m_RegistryMutex);
    m_IntentHandlers[static_cast<int>(type)] = handler;
    ELLE_LOG_DEBUG(L"QueueWorker", L"Registered intent handler for type=%d", static_cast<int>(type));
}



ElleResult ElleQueueWorker::Start()
{
    ELLE_LOG_INFO(L"QueueWorker", L"Starting poll loop. PollInterval=%dms", ElleConfig::Queue::POLL_INTERVAL_MS);

    m_StopEvent = CreateEventW(nullptr, TRUE, FALSE, nullptr);
    if (!m_StopEvent)
    {
        ELLE_LOG_WIN32(L"QueueWorker", L"CreateEvent(StopEvent) failed", GetLastError());
        return ElleResult::ERR_GENERIC;
    }

    m_Running = true;
    m_Thread = CreateThread(nullptr, 0, WorkerThreadProc, this, 0, nullptr);
    if (!m_Thread)
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"CreateThread failed: %u", GetLastError());
        ElleLogger::Get().WriteWin32Error(ElleLogLevel::ERROR, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf, GetLastError());
        m_Running = false;
        CloseHandle(m_StopEvent);
        m_StopEvent = nullptr;
        return ElleResult::ERR_GENERIC;
    }

    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Poll loop started. TID=%lu", GetThreadId(m_Thread));
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return ElleResult::OK;
}

void ElleQueueWorker::Stop()
{
    if (!m_Running)
        return;

    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Stopping poll loop. Intents=%llu IntentFail=%llu",
            m_IntentsProcessed.load(), m_IntentsFailed.load());
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    m_Running = false;

    if (m_StopEvent)
        SetEvent(m_StopEvent);

    if (m_Thread)
    {
        DWORD waitResult = WaitForSingleObject(m_Thread, 10000);  // 10 second graceful shutdown
        if (waitResult == WAIT_TIMEOUT)
        {
            wchar_t _elle_log_buf[256] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Worker thread did not exit in 10s — terminating");
            ElleLogger::Get().Write(ElleLogLevel::WARN, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
            TerminateThread(m_Thread, 1);
        }
        ELLE_SAFE_CLOSE_HANDLE(m_Thread);
    }

    ELLE_SAFE_CLOSE_HANDLE(m_StopEvent);
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Poll loop stopped");
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
}

DWORD WINAPI ElleQueueWorker::WorkerThreadProc(LPVOID lpParam)
{
    ElleQueueWorker* self = static_cast<ElleQueueWorker*>(lpParam);
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Worker thread running. TID=%lu", GetCurrentThreadId());
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    while (self->m_Running)
    {
        self->PollCycle();

        // Wait for poll interval or stop signal, whichever comes first
        DWORD waitResult = WaitForSingleObject(self->m_StopEvent, ElleConfig::Queue::POLL_INTERVAL_MS);
        if (waitResult == WAIT_OBJECT_0)
            break;  // Stop was signaled
    }

    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Worker thread exiting");
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return 0;
}

void ElleQueueWorker::PollCycle()
{
    // Intent poll only. ActionQueue is consumed exclusively by Elle.Service.Action.
    // QueueWorker never touches ActionQueue rows. Intent handlers call
    // CreateAction() to enqueue work, but do not execute it.
    std::vector<ElleIntent> intents;
    ElleResult r = m_IntentQueue.GetPendingIntents(intents, ElleConfig::Queue::MAX_BATCH_SIZE);

    if (r == ElleResult::OK && !intents.empty())
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"PollCycle: processing %zu intents", intents.size());
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        for (auto& intent : intents)
            ProcessIntent(intent);
    }

    // Periodic stale intent cleanup (~every 50 seconds at default poll rate)
    static DWORD cleanupCounter = 0;
    if (++cleanupCounter >= 100)
    {
        cleanupCounter = 0;
        int purged = 0;
        m_IntentQueue.PurgeStaleIntents(purged);
    }
}

void ElleQueueWorker::ProcessIntent(const ElleIntent& intent)
{
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Processing IntentID=%lld Type=%d Priority=%d",
            intent.IntentID, static_cast<int>(intent.Type), intent.Priority);
        ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    // Look up registered handler
    ElleIntentHandler handler;
    {
        std::lock_guard<std::mutex> lock(m_RegistryMutex);
        auto it = m_IntentHandlers.find(static_cast<int>(intent.Type));
        if (it != m_IntentHandlers.end())
            handler = it->second;
    }

    std::wstring responseJson;
    ElleResult handlerResult;

    if (handler)
    {
        handlerResult = handler(intent, responseJson);
        if (handlerResult == ElleResult::OK)
        {
            m_IntentsProcessed.fetch_add(1, std::memory_order_relaxed);
            {
                wchar_t _elle_log_buf[128] = {};
                _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"IntentID=%lld completed OK", intent.IntentID);
                ElleLogger::Get().Write(ElleLogLevel::INFO, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
            }
        }
        else
        {
            m_IntentsFailed.fetch_add(1, std::memory_order_relaxed);
            {
                wchar_t _elle_log_buf[256] = {};
                _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"IntentID=%lld handler returned %s",
                    intent.IntentID, ElleResultStr(handlerResult));
                ElleLogger::Get().Write(ElleLogLevel::WARN, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
            }

            if (responseJson.empty())
            {
                wchar_t errBuf[256] = {};
                _snwprintf_s(errBuf, _countof(errBuf), _TRUNCATE,
                    L"{\"error\":\"%s\"}", ElleResultStr(handlerResult));
                responseJson = errBuf;
            }
        }
    }
    else
    {
        // No handler registered — log and mark failed so C++ core knows
        {
            wchar_t _elle_log_buf[256] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"IntentID=%lld — no handler registered for Type=%d",
                intent.IntentID, static_cast<int>(intent.Type));
            ElleLogger::Get().Write(ElleLogLevel::WARN, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        }
        handlerResult = ElleResult::ERR_INTENT_UNSUPPORTED;
        responseJson = L"{\"error\":\"no_handler\"}";
        m_IntentsFailed.fetch_add(1, std::memory_order_relaxed);
    }

    // Write result back — this is what Python was failing to do
    ElleIntentStatus closeStatus = (handlerResult == ElleResult::OK)
        ? ElleIntentStatus::COMPLETED
        : ElleIntentStatus::FAILED;

    ElleResult closeResult = m_IntentQueue.SubmitIntentResponse(
        intent.IntentID, closeStatus, responseJson);

    if (closeResult != ElleResult::OK)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"CRITICAL: Failed to submit response for IntentID=%lld — C++ core will not receive result and trust score will not update",
            intent.IntentID);
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"QueueWorker", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
}

