// ElleActionQueue
// =============================================================================
ElleResult ElleActionQueue::CreateAction(
    ElleActionType      type,
    int64_t             sourceIntentID,
    const std::wstring& actionDataJson,
    DWORD               trustRequired,
    DWORD               timeoutMs,
    int64_t&            outActionID,
    const std::wstring& causalChainIDFromParent)
{
    ELLE_LOG_DEBUG(L"ActionQueue", L"CreateAction Type=%d SourceIntent=%lld TrustReq=%lu Epoch=%s",
        static_cast<int>(type), sourceIntentID, trustRequired,
        ElleEpochManager::Get().CurrentEpoch().c_str());

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    outActionID = 0;

    // Inherit epoch and causal chain from the parent intent.
    // If no parent intent exists (sourceIntentID == 0), generate a new causal chain.
    const std::wstring& epoch = ElleEpochManager::Get().CurrentEpoch();

    std::wstring causalChainID;
    if (sourceIntentID > 0 && !causalChainIDFromParent.empty())
        causalChainID = causalChainIDFromParent;
    else
        causalChainID = ElleEpochManager::GenerateGUID();

    std::vector<std::pair<std::wstring, std::wstring>> params =
    {
        { L"@TypeID",           std::to_wstring(static_cast<int>(type)) },
        { L"@SourceIntentID",   std::to_wstring(sourceIntentID) },
        { L"@ActionData",       actionDataJson },
        { L"@TrustRequired",    std::to_wstring(trustRequired) },
        { L"@TimeoutMs",        std::to_wstring(timeoutMs) },
        { L"@EpochID",          epoch },
        { L"@CausalChainID",    causalChainID }
    };

    // sp_ExecuteAction returns two result sets in the same round-trip:
    //   Result set 1 (RowsAffected): how many rows the INSERT affected.
    //   Result set 2 (inserted row): ActionID, TypeID, StatusID, TrustRequired, CreatedAt.
    //
    // ActionID comes from result set 2 — from the row the server just wrote,
    // read back in the same call. No SCOPE_IDENTITY() on a separate round-trip,
    // no dependency on connection identity, no window for another statement to
    // reset SCOPE_IDENTITY before we read it.
    ElleSQLResult sqlResult;
    int64_t insertedActionID    = 0;
    int     insertedTypeID      = -1;
    int     insertedStatusID    = -1;
    bool    rowReturned         = false;

    ElleResult r = conn->ExecProcStructured(
        L"sp_ExecuteAction",
        params,
        sqlResult,
        [&](const std::vector<std::wstring>& row)
        {
            // Row layout: ActionID, TypeID, StatusID, TrustRequired, CreatedAt
            if (row.size() >= 3)
            {
                insertedActionID  = _wtoi64(row[0].c_str());
                insertedTypeID    = _wtoi(row[1].c_str());
                insertedStatusID  = _wtoi(row[2].c_str());
                rowReturned       = true;
            }
        }
    );

    // Write succeeded check: proc executed and RowsAffected == 1
    if (r != ElleResult::OK || !sqlResult.WriteSucceeded)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"CreateAction WRITE FAILED: Type=%d SourceIntent=%lld RowsAffected=%d Error=%s",
            static_cast<int>(type), sourceIntentID,
            sqlResult.RowsAffected, sqlResult.ErrorDetail.c_str());
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ActionQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return (r != ElleResult::OK) ? r : ElleResult::ERR_SQL_QUERY;
    }

    // Write verified check: the row exists and the fields match what we sent
    if (!rowReturned || insertedActionID == 0)
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"CreateAction WRITE UNVERIFIED: proc returned no row or ActionID=0. RowsAffected=%d — INSERT may not have committed.",
            sqlResult.RowsAffected);
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ActionQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (insertedTypeID != static_cast<int>(type))
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"CreateAction WRITE UNVERIFIED: ActionID=%lld TypeID mismatch — sent %d, DB has %d",
            insertedActionID, static_cast<int>(type), insertedTypeID);
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ActionQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (insertedStatusID != static_cast<int>(ElleActionStatus::PENDING))
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"CreateAction WRITE UNVERIFIED: ActionID=%lld initial StatusID is %d, expected %d (PENDING)",
            insertedActionID, insertedStatusID, static_cast<int>(ElleActionStatus::PENDING));
        ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ActionQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    outActionID = insertedActionID;
    {
        wchar_t _elle_log_buf[256] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"CreateAction verified: ActionID=%lld Type=%d Status=PENDING",
            outActionID, static_cast<int>(type));
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"ActionQueue", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }
    return ElleResult::OK;
}

ElleResult ElleActionQueue::GetPendingActions(
    std::vector<ElleAction>& outActions,
    int maxBatch)
{
    ELLE_LOG_TRACE(L"ActionQueue", L"GetPendingActions maxBatch=%d", maxBatch);

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    std::vector<std::pair<std::wstring, std::wstring>> params =
    {
        { L"@MaxBatch", std::to_wstring(maxBatch) }
    };

    outActions.clear();
    ElleResult r = conn->ExecProc(L"sp_GetPendingActions", params);
    if (r == ElleResult::ERR_SQL_NO_DATA)
        return ElleResult::ERR_QUEUE_EMPTY;

    if (r != ElleResult::OK)
    {
        ELLE_LOG_ERROR(L"ActionQueue", L"sp_GetPendingActions failed: %s", conn->LastError.c_str());
        return r;
    }

    int claimedActions = 0;
    r = conn->QueryRows(
        L"SELECT ActionID, SourceIntentID, TypeID, StatusID, ActionData, "
        L"Result, CreatedAt, CompletedAt, TrustRequired, TimeoutMs "
        L"FROM ElleCore.dbo.ActionQueue "
        L"WHERE StatusID = 1 AND ClaimedByThread = @@SPID "
        L"ORDER BY CreatedAt ASC",
        [&](const std::vector<std::wstring>& row)
        {
            outActions.push_back(ActionFromRow(row));
        },
        claimedActions
    );

    if (r == ElleResult::ERR_SQL_NO_DATA)
        r = ElleResult::OK;

    ELLE_LOG_DEBUG(L"ActionQueue", L"GetPendingActions claimed %zu actions", outActions.size());
    return outActions.empty() ? ElleResult::ERR_QUEUE_EMPTY : ElleResult::OK;
}

ElleResult ElleActionQueue::SubmitActionResult(
    int64_t actionID,
    ElleActionStatus status,
    const std::wstring& resultJson)
{
    ELLE_LOG_DEBUG(L"ActionQueue", L"SubmitActionResult ActionID=%lld Status=%d",
        actionID, static_cast<int>(status));

    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    std::vector<std::pair<std::wstring, std::wstring>> params =
    {
        { L"@ActionID",     std::to_wstring(actionID) },
        { L"@StatusID",     std::to_wstring(static_cast<int>(status)) },
        { L"@Result",       resultJson }
    };

    // sp_SubmitActionResult SELECTs the updated row back so we verify all
    // written fields — StatusID, Result, and CompletedAt — in one round-trip.
    ElleSQLResult sqlResult;
    int   verifiedStatus    = -1;
    bool  completedAtSet    = false;
    bool  rowReturned       = false;
    std::wstring verifiedResult;

    ElleResult r = conn->ExecProcStructured(
        L"sp_SubmitActionResult",
        params,
        sqlResult,
        [&](const std::vector<std::wstring>& row)
        {
            // Row layout from proc: ActionID, StatusID, Result, CompletedAt
            if (row.size() >= 4)
            {
                verifiedStatus   = _wtoi(row[1].c_str());
                verifiedResult   = row[2];
                completedAtSet   = !row[3].empty();  // CompletedAt must be non-null
                rowReturned      = true;
            }
        }
    );

    if (r != ElleResult::OK || !sqlResult.WriteSucceeded)
    {
        ELLE_LOG_ERROR(L"ActionQueue",
            L"SubmitActionResult WRITE FAILED: ActionID=%lld RowsAffected=%d Error=%s",
            actionID, sqlResult.RowsAffected, sqlResult.ErrorDetail.c_str());
        return (r != ElleResult::OK) ? r : ElleResult::ERR_SQL_QUERY;
    }

    if (!rowReturned)
    {
        ELLE_LOG_ERROR(L"ActionQueue",
            L"SubmitActionResult WRITE UNVERIFIED: ActionID=%lld — proc returned no row",
            actionID);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (verifiedStatus != static_cast<int>(status))
    {
        ELLE_LOG_ERROR(L"ActionQueue",
            L"SubmitActionResult WRITE UNVERIFIED: ActionID=%lld StatusID mismatch — "
            L"wrote %d, DB has %d",
            actionID, static_cast<int>(status), verifiedStatus);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (!completedAtSet)
    {
        ELLE_LOG_ERROR(L"ActionQueue",
            L"SubmitActionResult WRITE UNVERIFIED: ActionID=%lld CompletedAt is NULL — "
            L"UPDATE ran but timestamp did not commit",
            actionID);
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    if (!resultJson.empty() && verifiedResult != resultJson)
    {
        ELLE_LOG_ERROR(L"ActionQueue",
            L"SubmitActionResult WRITE UNVERIFIED: ActionID=%lld Result mismatch — "
            L"wrote %zu chars, DB has %zu chars",
            actionID, resultJson.size(), verifiedResult.size());
        return ElleResult::ERR_SQL_WRITE_UNVERIFIED;
    }

    sqlResult.WriteVerified = true;
    ELLE_LOG_DEBUG(L"ActionQueue",
        L"ActionID=%lld write succeeded and verified. status=%d result_len=%zu completedAt=%s",
        actionID, verifiedStatus, verifiedResult.size(), completedAtSet ? L"SET" : L"NULL");
    return ElleResult::OK;
}

ElleResult ElleActionQueue::PurgeOldResults(int& outPurged)
{
    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    outPurged = 0;

    wchar_t sql[512] = {};
    _snwprintf_s(sql, _countof(sql), _TRUNCATE,
        L"DELETE FROM ElleCore.dbo.ActionQueue "
        L"WHERE StatusID IN (%d, %d) "
        L"AND DATEDIFF(SECOND, CompletedAt, GETDATE()) > %d",
        static_cast<int>(ElleActionStatus::SUCCESS),
        static_cast<int>(ElleActionStatus::FAILED),
        ElleConfig::Queue::ACTION_RESULT_RETAIN_SEC
    );

    wchar_t batchSql[768] = {};
    _snwprintf_s(batchSql, _countof(batchSql), _TRUNCATE,
        L"DECLARE @affected INT; "
        L"%s; "
        L"SET @affected = @@ROWCOUNT; "
        L"SELECT @affected;",
        sql
    );

    int rowCount = 0;
    ElleResult r = conn->QueryRows(batchSql,
        [&](const std::vector<std::wstring>& row)
        {
            if (!row.empty() && !row[0].empty())
                outPurged = _wtoi(row[0].c_str());
        },
        rowCount
    );

    if (r == ElleResult::ERR_SQL_NO_DATA)
        r = ElleResult::OK;

    if (outPurged > 0)
        ELLE_LOG_DEBUG(L"ActionQueue", L"Purged %d old action results", outPurged);

    return r;
}

ElleResult ElleActionQueue::GetLockedCount(int& outCount)
{
    ElleSQLScope conn(ElleDB::CORE);
    if (!conn.Valid())
        return ElleResult::ERR_SQL_CONNECT;

    outCount = 0;
    conn->Query(
        L"SELECT COUNT(*) FROM ElleCore.dbo.ActionQueue WHERE StatusID = 1",
        [&](const std::vector<std::wstring>& row)
        {
            if (!row.empty()) outCount = _wtoi(row[0].c_str());
        });
    return ElleResult::OK;
}

