// =============================================================================
// Helper: parse a single ElleIntent from a SQL row
// Row order: IntentID, TypeID, StatusID, IntentData, Response,
//            CreatedAt, UpdatedAt, TrustRequired, Priority
// =============================================================================
static ElleIntent IntentFromRow(const std::vector<std::wstring>& row)
{
    ElleIntent intent = {};
    if (row.size() < 9)
        return intent;

    intent.IntentID         = _wtoi64(row[0].c_str());
    intent.Type             = static_cast<ElleIntentType>(_wtoi(row[1].c_str()));
    intent.Status           = static_cast<ElleIntentStatus>(_wtoi(row[2].c_str()));
    intent.IntentData       = row[3];
    intent.Response         = row[4];
    // CreatedAt / UpdatedAt stored as strings in SQL — store raw for now
    intent.TrustRequired    = (DWORD)_wtoi(row[7].c_str());
    intent.Priority         = _wtoi(row[8].c_str());
    return intent;
}

// Helper: parse a single ElleAction from a SQL row
// Row order: ActionID, SourceIntentID, TypeID, StatusID, ActionData,
//            Result, CreatedAt, CompletedAt, TrustRequired, TimeoutMs
static ElleAction ActionFromRow(const std::vector<std::wstring>& row)
{
    ElleAction action = {};
    if (row.size() < 10)
        return action;

    action.ActionID         = _wtoi64(row[0].c_str());
    action.SourceIntentID   = _wtoi64(row[1].c_str());
    action.Type             = static_cast<ElleActionType>(_wtoi(row[2].c_str()));
    action.Status           = static_cast<ElleActionStatus>(_wtoi(row[3].c_str()));
    action.ActionData       = row[4];
    action.Result           = row[5];
    action.TrustRequired    = (DWORD)_wtoi(row[8].c_str());
    action.TimeoutMs        = (DWORD)_wtoi(row[9].c_str());
    return action;
}

