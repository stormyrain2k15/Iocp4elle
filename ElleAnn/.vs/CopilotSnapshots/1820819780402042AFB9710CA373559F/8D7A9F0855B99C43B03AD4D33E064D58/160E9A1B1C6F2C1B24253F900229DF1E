    // -------------------------------------------------------------------------
    // MEMORY — STM/LTM parameters
    // -------------------------------------------------------------------------
    namespace Memory
    {
        inline constexpr int    STM_CAPACITY             = 256;     // Max items in short-term memory
        inline constexpr DWORD  STM_DECAY_MIN_MS         = 5000;    // 5 seconds minimum STM life
        inline constexpr DWORD  STM_DECAY_MAX_MS         = 30000;   // 30 seconds maximum STM life
        inline constexpr DWORD  RECALL_INTERVAL_MS       = 30000;   // Recall fires every 30 seconds
        inline constexpr int    RECALL_COOLDOWN_SEC      = 3600;    // 1 hour between recalls of same memory
        inline constexpr int    CONSOLIDATION_INTERVAL_SEC = 300;   // STM → LTM every 5 minutes
        inline constexpr int    RECALL_RESULT_LIMIT      = 5;       // Max memories injected per recall
