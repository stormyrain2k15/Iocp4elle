#pragma once
// =============================================================================
// ElleConfig.h — Central Configuration for the Elle-Ann ESI Platform
// All services include this. All tunable constants live here.
// Edit this file to change behavior across the entire system without recompiling
// individual services. Runtime overrides are loaded from ElleAnn.config at startup.
// =============================================================================

#include <string>
#include <Windows.h>

namespace ElleConfig
{
    // -------------------------------------------------------------------------
    // DATABASE — SQL Server connection parameters
    // -------------------------------------------------------------------------
    namespace DB
    {
        // Primary connection string template — populated at runtime from config file
        // Default targets local SQL Server instance named ELLE
        inline constexpr const wchar_t* SERVER          = L"localhost\\ELLE";
        inline constexpr const wchar_t* DRIVER          = L"{ODBC Driver 17 for SQL Server}";

        // Database names — match the existing schema exactly
        inline constexpr const wchar_t* DB_CORE         = L"ElleCore";
        inline constexpr const wchar_t* DB_MEMORY       = L"ElleMemory";
        inline constexpr const wchar_t* DB_KNOWLEDGE    = L"ElleKnowledge";
        inline constexpr const wchar_t* DB_SYSTEM       = L"ElleSystem";
        inline constexpr const wchar_t* DB_HEART        = L"ElleHeart";

        // Connection pool sizing
        inline constexpr int POOL_MIN_CONNECTIONS       = 2;
        inline constexpr int POOL_MAX_CONNECTIONS       = 16;
        inline constexpr int CONNECTION_TIMEOUT_SEC     = 10;
        inline constexpr int QUERY_TIMEOUT_SEC          = 30;

        // Authentication mode
        // "windows" = Trusted_Connection=Yes (requires SQL login for service account)
        // "sql"     = SQL Server auth using DB_UID and DB_PWD below
        inline constexpr const wchar_t* AUTH_MODE       = L"windows";

        // SQL Server credentials — used only when AUTH_MODE = "sql"
        // Override in ElleAnn.config with DB_AUTH=sql, DB_UID=..., DB_PWD=...
        inline constexpr const wchar_t* DB_UID          = L"";
        inline constexpr const wchar_t* DB_PWD          = L"";

        // Connection retry behavior
        inline constexpr int RETRY_COUNT                = 5;
        inline constexpr int RETRY_DELAY_MS             = 2000;
    }

    // -------------------------------------------------------------------------
    // QUEUE — IntentQueue / ActionQueue IPC parameters
    // -------------------------------------------------------------------------
    namespace Queue
    {
        // How often the queue worker polls for new intents (milliseconds)
        inline constexpr DWORD POLL_INTERVAL_MS         = 500;

        // Maximum intents to dequeue and process in a single poll cycle
        inline constexpr int MAX_BATCH_SIZE             = 10;

        // How long an intent can sit unprocessed before it is marked stale
        inline constexpr int INTENT_STALE_TIMEOUT_SEC   = 30;

        // How long an action result is held in ActionQueue before purge
        inline constexpr int ACTION_RESULT_RETAIN_SEC   = 60;

        // Maximum concurrent intent processors
        inline constexpr int MAX_INTENT_WORKERS         = 4;
    }

