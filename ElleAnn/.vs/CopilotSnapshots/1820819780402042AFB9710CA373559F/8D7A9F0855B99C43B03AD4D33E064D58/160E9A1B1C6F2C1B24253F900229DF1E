    }

    // -------------------------------------------------------------------------
    // TRUST SYSTEM — capability gating thresholds
    // -------------------------------------------------------------------------
    namespace Trust
    {
        inline constexpr int    LEVEL_0_MAX              = 9;       // Safe ops only
        inline constexpr int    LEVEL_1_MAX              = 29;      // File access
        inline constexpr int    LEVEL_2_MAX              = 59;      // System modifications
        inline constexpr int    LEVEL_3_MIN              = 60;      // Self-modification
        inline constexpr int    SUCCESS_REWARD           = 2;       // Trust gained on action success
        inline constexpr int    FAILURE_PENALTY          = 3;       // Trust lost on action failure
        inline constexpr int    SELF_MODIFY_THRESHOLD    = 50;      // Minimum for self-modification actions
    }

    // -------------------------------------------------------------------------
    // FRESHNESS — maximum acceptable age for shared state before a consumer
    // should treat it as stale and log a warning rather than act on it silently.
    // These are read by the Cognitive, Action, and Lua services.
    // -------------------------------------------------------------------------
    namespace Freshness
    {
        // TrustState: trust score should be updated by the C++ core regularly.
        // If it hasn't been touched in this many seconds, the Action service
        // should warn before applying trust adjustments.
        inline constexpr int TRUST_STATE_MAX_AGE_SEC        = 60;

        // DriveState: boredom/curiosity/attachment/anxiety updated by C++ core.
        // If stale, Cognitive should not generate autonomous self-prompt intents
        // based on drives that may no longer reflect Elle's actual state.
        inline constexpr int DRIVE_STATE_MAX_AGE_SEC        = 30;

        // EmotionalState: persisted by Emotional service every 5 seconds.
        // If a consumer reads state older than this, it should log a staleness
        // warning — the Emotional service may have crashed.
        inline constexpr int EMOTIONAL_STATE_MAX_AGE_SEC    = 15;

        // StateVersion: if the StateVersion on a table hasn't changed since
        // the last read, the consumer can skip processing (no-op optimisation).
        // This is advisory — consumers that need current state should always
        // read regardless.
        inline constexpr int STATE_VERSION_UNCHANGED        = 0;  // Placeholder constant
    }

