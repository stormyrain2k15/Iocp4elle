    // -------------------------------------------------------------------------
    // LOGGING — see ElleLogger.h for level definitions
    // -------------------------------------------------------------------------
    namespace Log
    {
        // Log output targets (can be combined with bitwise OR at runtime)
        inline constexpr DWORD TARGET_FILE              = 0x01;
        inline constexpr DWORD TARGET_SQL               = 0x02;
        inline constexpr DWORD TARGET_DEBUGGER          = 0x04;    // OutputDebugStringW
        inline constexpr DWORD TARGET_CONSOLE           = 0x08;    // Only valid when running in console mode

        // Default targets — file and SQL
        inline constexpr DWORD DEFAULT_TARGETS          = TARGET_FILE | TARGET_SQL;

        // Log file locations — relative to service executable directory
        inline constexpr const wchar_t* LOG_DIR         = L"C:\\Elle\\Logs\\";
        inline constexpr const wchar_t* LOG_EXTENSION   = L".log";

        // File rotation — roll over when log file exceeds this size
        inline constexpr SIZE_T MAX_LOG_FILE_BYTES      = 50 * 1024 * 1024;  // 50MB per file

        // How many rotated log files to keep before deleting oldest
        inline constexpr int    MAX_ROTATED_FILES       = 10;

        // Flush interval — logs are buffered and flushed to disk at this interval
        inline constexpr DWORD  FLUSH_INTERVAL_MS       = 1000;

        // Default minimum log level written to file/SQL
        // 0=TRACE 1=DEBUG 2=INFO 3=WARN 4=ERROR 5=FATAL
        inline constexpr int    DEFAULT_LEVEL           = 0;       // TRACE — log everything
    }

