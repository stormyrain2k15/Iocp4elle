    // HEARTBEAT / WATCHDOG
    // -------------------------------------------------------------------------
    namespace Heartbeat
    {
        inline constexpr DWORD  PING_INTERVAL_MS         = 5000;    // Heartbeat every 5 seconds
        inline constexpr DWORD  WATCHDOG_CHECK_MS        = 10000;   // Watchdog checks every 10 seconds
        inline constexpr int    STALE_WORKER_TIMEOUT_SEC = 60;      // Worker considered dead after 60s silence
        inline constexpr int    DEAD_MAN_TIMEOUT_SEC     = 300;     // Dead man switch fires after 5 minutes
        inline constexpr int    BIOMETRIC_TIMEOUT_SEC    = 120;     // Crystal watch/ring keep-alive timeout
    }

