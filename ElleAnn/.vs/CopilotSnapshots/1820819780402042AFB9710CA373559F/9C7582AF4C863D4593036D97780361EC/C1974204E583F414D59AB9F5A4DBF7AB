ElleSQLScope::ElleSQLScope(ElleDB db)
    : m_DB(db)
    , m_Conn(nullptr)
{
    m_Conn = ElleSQLPool::Get().Checkout(db);
}

ElleSQLScope::~ElleSQLScope()
{
    if (m_Conn)
        ElleSQLPool::Get().Return(m_Conn);
}

