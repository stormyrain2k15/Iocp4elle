ElleSQLConnection::ElleSQLConnection(ElleDB db, const std::wstring& connStr)
    : Database(db)
    , m_ConnStr(connStr)
    , m_hEnv(nullptr)
    , m_hDBC(nullptr)
    , m_Connected(false)
{
}

ElleSQLConnection::~ElleSQLConnection()
{
    Disconnect();
}

ElleResult ElleSQLConnection::Connect()
{
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Connecting to DB[%d]", static_cast<int>(Database));
                ElleLogger::Get().Write(ElleLogLevel::TRACE, L"ElleSQLConn", __FILE__, __LINE__, __FUNCTION__, _elle_log_buf);
    }

    SQLRETURN ret;

    ret = SQLAllocHandle(SQL_HANDLE_ENV, SQL_NULL_HANDLE, &m_hEnv);
    if (!SQL_SUCCEEDED(ret))
    {
        LastError = L"SQLAllocHandle(ENV) failed";
        ELLE_LOG_ERROR(L"ElleSQLConn", L"%s", LastError.c_str());
        return ElleResult::ERR_SQL_CONNECT;
    }

    SQLSetEnvAttr(m_hEnv, SQL_ATTR_ODBC_VERSION, (SQLPOINTER)SQL_OV_ODBC3, 0);

    ret = SQLAllocHandle(SQL_HANDLE_DBC, m_hEnv, &m_hDBC);
    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_ENV, m_hEnv);
        SQLFreeHandle(SQL_HANDLE_ENV, m_hEnv);
        m_hEnv = nullptr;
        {
            wchar_t _elle_log_buf[1024] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"SQLAllocHandle(DBC) failed: %s", LastError.c_str());
            ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
        }
        return ElleResult::ERR_SQL_CONNECT;
    }

    // Set connection timeout
    SQLUINTEGER timeout = ElleConfig::DB::CONNECTION_TIMEOUT_SEC;
    SQLSetConnectAttr(m_hDBC, SQL_ATTR_CONNECTION_TIMEOUT, (SQLPOINTER)(UINT_PTR)timeout, 0);
    SQLSetConnectAttr(m_hDBC, SQL_ATTR_LOGIN_TIMEOUT, (SQLPOINTER)(UINT_PTR)timeout, 0);

    SQLWCHAR outConnStr[1024] = {};
    SQLSMALLINT outLen = 0;

    ret = SQLDriverConnectW(
        m_hDBC,
        nullptr,
        (SQLWCHAR*)m_ConnStr.c_str(),
        (SQLSMALLINT)m_ConnStr.length(),
        outConnStr,
        1024,
        &outLen,
        SQL_DRIVER_NOPROMPT
    );

    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_DBC, m_hDBC);
        SQLFreeHandle(SQL_HANDLE_DBC, m_hDBC);
        SQLFreeHandle(SQL_HANDLE_ENV, m_hEnv);
        m_hDBC = nullptr;
        m_hEnv = nullptr;
        ELLE_LOG_ERROR(L"ElleSQLConn", L"SQLDriverConnect failed for DB[%d]: %s",
            static_cast<int>(Database), LastError.c_str());
        return ElleResult::ERR_SQL_CONNECT;
    }

    m_Connected = true;
    {
        wchar_t _elle_log_buf[1024] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE,
            L"Connected to DB[%d] (%s)", static_cast<int>(Database), s_DBNames[static_cast<int>(Database)]);
        ElleLogger::Get().Write(ElleLogLevel::DEBUG, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
    }
    return ElleResult::OK;
}

void ElleSQLConnection::Disconnect()
{
    if (m_hDBC)
    {
        SQLDisconnect(m_hDBC);
        SQLFreeHandle(SQL_HANDLE_DBC, m_hDBC);
        m_hDBC = nullptr;
    }
    if (m_hEnv)
    {
        SQLFreeHandle(SQL_HANDLE_ENV, m_hEnv);
        m_hEnv = nullptr;
    }
    m_Connected = false;
}

bool ElleSQLConnection::IsConnected() const
{
    return m_Connected && m_hDBC != nullptr;
}

bool ElleSQLConnection::Ping()
{
    if (!IsConnected())
        return false;

    SQLHSTMT hStmt = nullptr;
    SQLAllocHandle(SQL_HANDLE_STMT, m_hDBC, &hStmt);
    SQLRETURN ret = SQLExecDirectW(hStmt, (SQLWCHAR*)L"SELECT 1", SQL_NTS);
    SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
    return SQL_SUCCEEDED(ret);
}

ElleResult ElleSQLConnection::Execute(const std::wstring& sql)
{
    {
        wchar_t _elle_log_buf[2048] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Execute: %s", sql.c_str());
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
    }

    if (!IsConnected())
        return ElleResult::ERR_SQL_CONNECT;

    SQLHSTMT hStmt = nullptr;
    SQLAllocHandle(SQL_HANDLE_STMT, m_hDBC, &hStmt);

    SQLUINTEGER qTimeout = ElleConfig::DB::QUERY_TIMEOUT_SEC;
    SQLSetStmtAttr(hStmt, SQL_ATTR_QUERY_TIMEOUT, (SQLPOINTER)(UINT_PTR)qTimeout, 0);

    SQLRETURN ret = SQLExecDirectW(hStmt, (SQLWCHAR*)sql.c_str(), SQL_NTS);

    ElleResult result = ElleResult::OK;
    if (!SQL_SUCCEEDED(ret) && ret != SQL_NO_DATA)
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        {
            wchar_t _elle_log_buf[2048] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Execute failed: %s | SQL: %s", LastError.c_str(), sql.c_str());
            ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
        }
        result = ElleResult::ERR_SQL_QUERY;
    }

    SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
    return result;
}

ElleResult ElleSQLConnection::ExecuteParams(
    const std::wstring& sql,
    const std::vector<std::wstring>& params)
{
    {
        wchar_t _elle_log_buf[512] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"ExecuteParams: %s [%zu params]", sql.c_str(), params.size());
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
    }

    if (!IsConnected())
        return ElleResult::ERR_SQL_CONNECT;

    SQLHSTMT hStmt = nullptr;
    SQLAllocHandle(SQL_HANDLE_STMT, m_hDBC, &hStmt);

    SQLUINTEGER qTimeout = ElleConfig::DB::QUERY_TIMEOUT_SEC;
    SQLSetStmtAttr(hStmt, SQL_ATTR_QUERY_TIMEOUT, (SQLPOINTER)(UINT_PTR)qTimeout, 0);

    SQLRETURN ret = SQLPrepareW(hStmt, (SQLWCHAR*)sql.c_str(), SQL_NTS);
    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        {
            wchar_t _elle_log_buf[1024] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"SQLPrepare failed: %s", LastError.c_str());
            ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
        }
        SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
        return ElleResult::ERR_SQL_QUERY;
    }

    std::vector<SQLLEN> indicators(params.size(), SQL_NTS);
    for (SQLUSMALLINT i = 0; i < (SQLUSMALLINT)params.size(); i++)
    {
        SQLBindParameter(
            hStmt, (SQLUSMALLINT)(i + 1),
            SQL_PARAM_INPUT, SQL_C_WCHAR, SQL_WVARCHAR,
            params[i].length(), 0,
            (SQLPOINTER)params[i].c_str(), 0,
            &indicators[i]
        );
    }

    ret = SQLExecute(hStmt);
    ElleResult result = ElleResult::OK;
    if (!SQL_SUCCEEDED(ret) && ret != SQL_NO_DATA)
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        ELLE_LOG_ERROR(L"ElleSQLConn", L"ExecuteParams failed: %s", LastError.c_str());
        result = ElleResult::ERR_SQL_QUERY;
    }

    SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
    return result;
}

ElleResult ElleSQLConnection::Query(
    const std::wstring& sql,
    std::function<void(const std::vector<std::wstring>&)> rowCallback)
{
    {
        wchar_t _elle_log_buf[2048] = {};
        _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Query: %s", sql.c_str());
        ElleLogger::Get().Write(ElleLogLevel::TRACE, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
    }

    if (!IsConnected())
        return ElleResult::ERR_SQL_CONNECT;

    SQLHSTMT hStmt = nullptr;
    SQLAllocHandle(SQL_HANDLE_STMT, m_hDBC, &hStmt);

    SQLUINTEGER qTimeout = ElleConfig::DB::QUERY_TIMEOUT_SEC;
    SQLSetStmtAttr(hStmt, SQL_ATTR_QUERY_TIMEOUT, (SQLPOINTER)(UINT_PTR)qTimeout, 0);

    SQLRETURN ret = SQLExecDirectW(hStmt, (SQLWCHAR*)sql.c_str(), SQL_NTS);
    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        {
            wchar_t _elle_log_buf[1024] = {};
            _snwprintf_s(_elle_log_buf, _countof(_elle_log_buf), _TRUNCATE, L"Query exec failed: %s", LastError.c_str());
            ElleLogger::Get().Write(ElleLogLevel::ERROR, L"ElleSQLConn", __FILEW__, __LINE__, __FUNCTIONW__, _elle_log_buf);
        }
        SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
        return ElleResult::ERR_SQL_QUERY;
    }

    ElleResult result = ExecuteStatement(hStmt, rowCallback);
    SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
    return result;
}

ElleResult ElleSQLConnection::QueryParams(
    const std::wstring& sql,
    const std::vector<std::wstring>& params,
    std::function<void(const std::vector<std::wstring>&)> rowCallback)
{
    ELLE_LOG_TRACE(L"ElleSQLConn", L"QueryParams: %s [%zu params]", sql.c_str(), params.size());

    if (!IsConnected())
        return ElleResult::ERR_SQL_CONNECT;

    SQLHSTMT hStmt = nullptr;
    SQLAllocHandle(SQL_HANDLE_STMT, m_hDBC, &hStmt);

    SQLUINTEGER qTimeout = ElleConfig::DB::QUERY_TIMEOUT_SEC;
    SQLSetStmtAttr(hStmt, SQL_ATTR_QUERY_TIMEOUT, (SQLPOINTER)(UINT_PTR)qTimeout, 0);

    SQLRETURN ret = SQLPrepareW(hStmt, (SQLWCHAR*)sql.c_str(), SQL_NTS);
    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
        return ElleResult::ERR_SQL_QUERY;
    }

    std::vector<SQLLEN> indicators(params.size(), SQL_NTS);
    for (SQLUSMALLINT i = 0; i < (SQLUSMALLINT)params.size(); i++)
    {
        SQLBindParameter(
            hStmt, (SQLUSMALLINT)(i + 1),
            SQL_PARAM_INPUT, SQL_C_WCHAR, SQL_WVARCHAR,
            params[i].length(), 0,
            (SQLPOINTER)params[i].c_str(), 0,
            &indicators[i]
        );
    }

    ret = SQLExecute(hStmt);
    if (!SQL_SUCCEEDED(ret))
    {
        CaptureError(SQL_HANDLE_STMT, hStmt);
        SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
        return ElleResult::ERR_SQL_QUERY;
    }

    ElleResult result = ExecuteStatement(hStmt, rowCallback);
    SQLFreeHandle(SQL_HANDLE_STMT, hStmt);
    return result;
}

ElleResult ElleSQLConnection::ExecProc(
    const std::wstring& procName,
    const std::vector<std::pair<std::wstring, std::wstring>>& params)
{
    // Build: { CALL procName(?, ?, ...) }
    std::wstring sql = L"{ CALL " + procName + L"(";
    for (size_t i = 0; i < params.size(); i++)
    {
        sql += (i == 0) ? L"?" : L", ?";
    }
    sql += L") }";

    ELLE_LOG_TRACE(L"ElleSQLConn", L"ExecProc: %s [%zu params]", sql.c_str(), params.size());

    std::vector<std::wstring> values;
    values.reserve(params.size());
    for (auto& p : params)
        values.push_back(p.second);

    return ExecuteParams(sql, values);
}

ElleResult ElleSQLConnection::ExecuteStatement(
    SQLHSTMT hStmt,
    std::function<void(const std::vector<std::wstring>&)> rowCallback,
    int* outRowCount)
{
    SQLSMALLINT colCount = 0;
    SQLNumResultCols(hStmt, &colCount);

    if (outRowCount) *outRowCount = 0;

    if (colCount == 0)
        return ElleResult::OK;  // DML or no result set — not an error

    int rowCount = 0;
    SQLRETURN fetchRet;

    // SQL_SUCCESS_WITH_INFO is a valid success return from SQLFetch.
    // Stopping only on SQL_SUCCESS silently drops rows when ODBC returns
    // an informational state (e.g. string truncation warning 01004).
    while (SQL_SUCCEEDED(fetchRet = SQLFetch(hStmt)))
    {
        std::vector<std::wstring> row;
        row.reserve(colCount);

        for (SQLUSMALLINT col = 1; col <= (SQLUSMALLINT)colCount; col++)
        {
            wchar_t buf[4096] = {};
            SQLLEN indicator = 0;
            SQLRETURN ret = SQLGetData(hStmt, col, SQL_C_WCHAR, buf, sizeof(buf), &indicator);

            if (SQL_SUCCEEDED(ret) && indicator != SQL_NULL_DATA)
                row.emplace_back(buf);
            else
                row.emplace_back(L"");
        }

        if (rowCallback)
            rowCallback(row);

        rowCount++;
    }

    if (outRowCount) *outRowCount = rowCount;

    ELLE_LOG_TRACE(L"ElleSQLConn", L"Query returned %d rows (last fetch ret=%d)", rowCount, (int)fetchRet);

    // Zero rows is a valid outcome at the connection layer.
    // Callers that need to distinguish empty vs non-empty results should
    // inspect outRowCount. ERR_SQL_NO_DATA is only returned by QueryRows().
    return ElleResult::OK;
}

void ElleSQLConnection::CaptureError(SQLSMALLINT handleType, SQLHANDLE handle)
{
    SQLWCHAR state[8] = {};
    SQLWCHAR msg[512] = {};
    SQLINTEGER nativeErr = 0;
    SQLSMALLINT msgLen = 0;

    LastError.clear();

    SQLSMALLINT recNum = 1;
    while (SQLGetDiagRecW(handleType, handle, recNum++, state, &nativeErr, msg, 512, &msgLen) == SQL_SUCCESS)
    {
        if (!LastError.empty())
            LastError += L" | ";
        LastError += L"[";
        LastError += state;
        LastError += L"] ";
        LastError += msg;
    }
}

