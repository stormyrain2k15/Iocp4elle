// =============================================================================
// Elle.Service.Cognitive — Service.cpp
//
// Intent parsing, attention management, and NLP-level message processing.
//
// What this service does:
//   - Monitors ElleCore.Messages for new incoming messages
//   - Parses intent signals from message text using keyword/pattern matching
//     against ElleKnowledge.Dictionary and ElleKnowledge.Triggers
//   - Determines whether a message warrants a SEND_MESSAGE or EXECUTE_COMMAND intent
//   - Manages attention threads: what Elle is currently focused on
//     and when she needs to re-engage (driven by boredom/curiosity drives)
//   - Pulls current drive states from the C++ core via ElleCore
//     and adjusts cognitive priority accordingly
//   - Detects self-prompt opportunities and inserts SELF_PROMPT intents
// =============================================================================

#include "../Shared/ElleServiceBase.h"
#include "../Shared/ElleEpoch.h"
#include "../Shared/ElleSQLConn.h"
#include "../Shared/ElleQueueIPC.h"
#include "../Shared/ElleLogger.h"
#include "../Shared/ElleConfig.h"
#include "../Shared/ElleTypes.h"
#include <vector>
#include <mutex>
#include <regex>

#define SVCNAME     ElleConfig::ServiceNames::COGNITIVE
#define LOG(lvl, fmt, ...) ELLE_LOG_##lvl(SVCNAME, fmt, ##__VA_ARGS__)

// Known command patterns — matched against incoming messages before full NLP
struct CommandPattern
{
    std::wstring    Keyword;
    ElleActionType  ActionType;
    int             TrustRequired;
};

static const CommandPattern COMMAND_PATTERNS[] =
{
    { L"vibrate",   ElleActionType::VIBRATE,        0 },
    { L"flash",     ElleActionType::FLASH,          0 },
    { L"notify",    ElleActionType::NOTIFY,         0 },
    { L"open",      ElleActionType::OPEN_APP,       10 },
    { L"remember",  ElleActionType::SAVE_MEMORY,    0 },
    { L"recall",    ElleActionType::READ_MEMORY,    0 },
};

// =============================================================================
// ElleCognitiveEngine
// =============================================================================
class ElleCognitiveEngine
{
    ELLE_NONCOPYABLE(ElleCognitiveEngine)
public:
    ElleCognitiveEngine()
        : m_Running(false)
        , m_MessagePollThread(nullptr)
        , m_SelfPromptThread(nullptr)
        , m_StopEvent(nullptr)
        , m_LastProcessedMessageID(0)
    {}

    ~ElleCognitiveEngine() { Stop(); }

    ElleResult Start(HANDLE stopEvent)
    {
        LOG(INFO, L"ElleCognitiveEngine starting");
        m_StopEvent = stopEvent;

        // Load NLP dictionary from ElleKnowledge
        LoadDictionary();

        // Find the highest existing message ID so we don't reprocess old messages
        {
            ElleSQLScope coreConn(ElleDB::CORE);
            if (coreConn.Valid())
            {
                coreConn->Query(
                    L"SELECT ISNULL(MAX(MessageID), 0) FROM ElleCore.dbo.Messages",
                    [&](const std::vector<std::wstring>& row)
                    {
                        if (!row.empty())
                            m_LastProcessedMessageID = _wtoi64(row[0].c_str());
                    }
                );
                LOG(INFO, L"ElleCognitiveEngine: Starting from MessageID=%lld", m_LastProcessedMessageID);
            }
        }

        m_Running = true;

        m_MessagePollThread = CreateThread(nullptr, 0, MessagePollProc, this, 0, nullptr);
        m_SelfPromptThread  = CreateThread(nullptr, 0, SelfPromptProc,  this, 0, nullptr);

        if (!m_MessagePollThread || !m_SelfPromptThread)
        {
            LOG(FATAL, L"CreateThread failed: %lu", GetLastError());
            m_Running = false;
            return ElleResult::ERR_GENERIC;
        }

        LOG(INFO, L"ElleCognitiveEngine running. Dictionary=%zu terms", m_Dictionary.size());
        return ElleResult::OK;
    }

    void Stop()
    {
        if (!m_Running) return;
        LOG(INFO, L"ElleCognitiveEngine stopping");
        m_Running = false;

        HANDLE threads[2] = { m_MessagePollThread, m_SelfPromptThread };
        WaitForMultipleObjects(2, threads, TRUE, 10000);
        ELLE_SAFE_CLOSE_HANDLE(m_MessagePollThread);
        ELLE_SAFE_CLOSE_HANDLE(m_SelfPromptThread);
        LOG(INFO, L"ElleCognitiveEngine stopped");
    }

    uint64_t MessagesProcessed() const { return m_MessagesProcessed; }
    uint64_t IntentsCreated() const    { return m_IntentsCreated; }

private:
    // Load the knowledge dictionary for NLP matching
    void LoadDictionary()
    {
        ElleSQLScope knowConn(ElleDB::KNOWLEDGE);
        if (!knowConn.Valid())
        {
            LOG(WARN, L"LoadDictionary: Cannot connect to ElleKnowledge — dictionary disabled");
            return;
        }

        m_Dictionary.clear();
        knowConn->Query(
            L"SELECT Word, Category, Weight FROM ElleKnowledge.dbo.Dictionary",
            [&](const std::vector<std::wstring>& row)
            {
                if (row.size() >= 3)
                {
                    std::wstring word = row[0];
                    for (auto& c : word) c = towlower(c);
                    m_Dictionary.push_back({ word, row[1], _wtof(row[2].c_str()) });
                }
            }
        );
        LOG(INFO, L"LoadDictionary: Loaded %zu dictionary terms", m_Dictionary.size());
    }

    // ==========================================================================
    // Message poll loop — picks up new incoming messages and processes them
    // ==========================================================================
    static DWORD WINAPI MessagePollProc(LPVOID param)
    {
        auto* engine = static_cast<ElleCognitiveEngine*>(param);
        LOG(INFO, L"Message poll loop running. Interval=1000ms");

        while (engine->m_Running)
        {
            DWORD wait = WaitForSingleObject(engine->m_StopEvent, 1000);
            if (wait == WAIT_OBJECT_0) break;
            engine->PollNewMessages();
        }

        LOG(INFO, L"Message poll loop exiting");
        return 0;
    }

    void PollNewMessages()
    {
        ElleSQLScope coreConn(ElleDB::CORE);
        if (!coreConn.Valid())
        {
            LOG(ERROR, L"PollNewMessages: DB unavailable");
            return;
        }

        std::vector<std::pair<int64_t, std::wstring>> newMessages;

        coreConn->QueryParams(
            L"SELECT MessageID, Content FROM ElleCore.dbo.Messages "
            L"WHERE MessageID > ? AND Direction = 'in' "
            L"ORDER BY MessageID ASC",
            { std::to_wstring(m_LastProcessedMessageID) },
            [&](const std::vector<std::wstring>& row)
            {
                if (row.size() >= 2)
                    newMessages.push_back({ _wtoi64(row[0].c_str()), row[1] });
            }
        );

        if (newMessages.empty())
            return;

        LOG(DEBUG, L"PollNewMessages: Found %zu new message(s)", newMessages.size());

        for (auto& [id, content] : newMessages)
        {
            ProcessMessage(id, content, coreConn.operator->());
            m_LastProcessedMessageID = id;
            m_MessagesProcessed.fetch_add(1, std::memory_order_relaxed);
        }
    }

    void ProcessMessage(int64_t messageID, const std::wstring& content, ElleSQLConnection* conn)
    {
        LOG(INFO, L"ProcessMessage: MessageID=%lld Content='%s'",
            messageID, content.substr(0, 60).c_str());

        std::wstring lowerContent = content;
        for (auto& c : lowerContent) c = towlower(c);

        // 1. Check for direct hardware/command keywords first
        for (auto& pattern : COMMAND_PATTERNS)
        {
            if (lowerContent.find(pattern.Keyword) != std::wstring::npos)
            {
                LOG(INFO, L"ProcessMessage: Command keyword '%s' detected", pattern.Keyword.c_str());

                wchar_t intentData[512] = {};
                _snwprintf_s(intentData, _countof(intentData), _TRUNCATE,
                    L"{\"message_id\":%lld,\"command\":\"%s\",\"content\":\"%s\"}",
                    messageID, pattern.Keyword.c_str(), content.c_str());

                conn->ExecuteParams(
                    L"INSERT INTO ElleCore.dbo.IntentQueue (TypeID, StatusID, IntentData, TrustRequired, Priority, CreatedAt) "
                    L"VALUES (9, 0, ?, ?, 10, GETDATE())",
                    { intentData, std::to_wstring(pattern.TrustRequired) }
                );

                m_IntentsCreated.fetch_add(1, std::memory_order_relaxed);
                return;  // Command detected — don't also generate a chat response
            }
        }

        // 2. NLP — score the message against dictionary terms
        double toneScore = 0.0;
        int termMatches = 0;

        for (auto& term : m_Dictionary)
        {
            if (lowerContent.find(term.Word) != std::wstring::npos)
            {
                toneScore += term.Weight;
                termMatches++;
                LOG(TRACE, L"ProcessMessage: Dictionary match '%s' weight=%.2f", term.Word.c_str(), term.Weight);
            }
        }

        // Normalize tone to [-1.0, 1.0]
        if (termMatches > 0)
        {
            toneScore = max(-1.0, min(1.0, toneScore / termMatches));
            LOG(DEBUG, L"ProcessMessage: Tone=%.3f from %d dictionary matches", toneScore, termMatches);

            // Push an EMOTION_SYNC intent with the tone so the Emotional engine can apply contagion
            wchar_t emotionData[256] = {};
            _snwprintf_s(emotionData, _countof(emotionData), _TRUNCATE,
                L"{\"tone\":%.3f,\"message_id\":%lld}", toneScore, messageID);

            conn->ExecuteParams(
                L"INSERT INTO ElleCore.dbo.IntentQueue (TypeID, StatusID, IntentData, TrustRequired, Priority, CreatedAt) "
                L"VALUES (6, 0, ?, 0, 3, GETDATE())",
                { emotionData }
            );
            m_IntentsCreated.fetch_add(1, std::memory_order_relaxed);
        }

        // 3. Generate SEND_MESSAGE intent so the C++ core can compose a reply via Groq
        wchar_t replyData[512] = {};
        _snwprintf_s(replyData, _countof(replyData), _TRUNCATE,
            L"{\"message_id\":%lld,\"tone\":%.3f}", messageID, toneScore);

        conn->ExecuteParams(
            L"INSERT INTO ElleCore.dbo.IntentQueue (TypeID, StatusID, IntentData, TrustRequired, Priority, CreatedAt) "
            L"VALUES (8, 0, ?, 0, 5, GETDATE())",
            { replyData }
        );
        m_IntentsCreated.fetch_add(1, std::memory_order_relaxed);

        LOG(INFO, L"ProcessMessage: Created intents for MessageID=%lld. Tone=%.3f", messageID, toneScore);
    }

    // ==========================================================================
    // Self-prompt loop — generates autonomous prompts when drives warrant it
    // ==========================================================================
    static DWORD WINAPI SelfPromptProc(LPVOID param)
    {
        auto* engine = static_cast<ElleCognitiveEngine*>(param);
        // Check for self-prompt conditions every 60 seconds
        LOG(INFO, L"Self-prompt loop running. Interval=60s");

        while (engine->m_Running)
        {
            DWORD wait = WaitForSingleObject(engine->m_StopEvent, 60000);
            if (wait == WAIT_OBJECT_0) break;
            engine->CheckSelfPromptConditions();
        }

        LOG(INFO, L"Self-prompt loop exiting");
        return 0;
    }

    void CheckSelfPromptConditions()
    {
        ElleSQLScope coreConn(ElleDB::CORE);
        if (!coreConn.Valid()) return;

        double boredom = 0.0, curiosity = 0.0;
        int    maxDriveAgeSec = 0;

        // Read drives AND freshness in one query. Acting on stale drive state
        // causes Elle to generate autonomous activity that no longer reflects
        // her actual condition — the C++ core may have already moved on.
        coreConn->Query(
            L"SELECT DriveType, Value, DATEDIFF(SECOND, UpdatedAt, GETDATE()) AS AgeSec "
            L"FROM ElleCore.dbo.DriveState WHERE DriveType IN ('boredom','curiosity')",
            [&](const std::vector<std::wstring>& row)
            {
                if (row.size() >= 3)
                {
                    int ageSec = _wtoi(row[2].c_str());
                    if (ageSec > maxDriveAgeSec) maxDriveAgeSec = ageSec;
                    if (row[0] == L"boredom")   boredom   = _wtof(row[1].c_str());
                    if (row[0] == L"curiosity") curiosity = _wtof(row[1].c_str());
                }
            }
        );

        // Freshness gate: if drives haven't been updated recently, suppress.
        if (maxDriveAgeSec > ElleConfig::Freshness::DRIVE_STATE_MAX_AGE_SEC)
        {
            LOG(WARN, L"CheckSelfPromptConditions: DriveState is %ds old (max=%d) — "
                L"C++ core may not be running. Suppressing autonomous self-prompt.",
                maxDriveAgeSec, ElleConfig::Freshness::DRIVE_STATE_MAX_AGE_SEC);
            return;
        }

        LOG(TRACE, L"CheckSelfPromptConditions: boredom=%.2f curiosity=%.2f age=%ds",
            boredom, curiosity, maxDriveAgeSec);

        if (boredom > 0.6 || curiosity > 0.7)
        {
            LOG(INFO, L"CheckSelfPromptConditions: Drives warrant self-prompt. "
                L"boredom=%.2f curiosity=%.2f age=%ds", boredom, curiosity, maxDriveAgeSec);

            wchar_t intentData[256] = {};
            _snwprintf_s(intentData, _countof(intentData), _TRUNCATE,
                L"{\"trigger\":\"drives\",\"boredom\":%.2f,\"curiosity\":%.2f,\"drive_age_sec\":%d}",
                boredom, curiosity, maxDriveAgeSec);

            coreConn->ExecuteParams(
                L"INSERT INTO ElleCore.dbo.IntentQueue "
                L"(TypeID, StatusID, IntentData, TrustRequired, Priority, SourceContext, EpochID, CausalChainID, CreatedAt) "
                L"VALUES (11, 0, ?, 0, 4, 'drive:autonomous', ?, NEWID(), GETDATE())",
                { intentData, ElleEpochManager::Get().CurrentEpoch() }
            );
            m_IntentsCreated.fetch_add(1, std::memory_order_relaxed);
        }
    }


    struct DictionaryTerm
    {
        std::wstring    Word;
        std::wstring    Category;
        double          Weight;
    };

    std::vector<DictionaryTerm>     m_Dictionary;
    HANDLE                          m_MessagePollThread;
    HANDLE                          m_SelfPromptThread;
    HANDLE                          m_StopEvent;
    volatile bool                   m_Running;
    int64_t                         m_LastProcessedMessageID;
    std::atomic<uint64_t>           m_MessagesProcessed{ 0 };
    std::atomic<uint64_t>           m_IntentsCreated{ 0 };
};

// =============================================================================
// ElleCognitiveService
// =============================================================================
class ElleCognitiveService : public ElleServiceBase
{
public:
    ElleCognitiveService() : ElleServiceBase(SVCNAME) {}

protected:
    ElleResult OnStart() override
    {
        LOG(INFO, L"OnStart: Initializing Cognitive service");
        ElleResult r = InitSharedInfrastructure();
        if (r != ElleResult::OK) return r;

        ElleEpochManager::Get().Init(false);

        RegisterWorker();

        r = m_Engine.Start(StopEvent());
        if (r != ElleResult::OK)
        {
            LOG(FATAL, L"CognitiveEngine::Start() failed: %s", ElleResultStr(r));
            return r;
        }

        LOG(INFO, L"Cognitive service running");
        return ElleResult::OK;
    }

    void OnStop() override
    {
        LOG(INFO, L"OnStop: Stopping Cognitive service. Processed=%llu IntentsCreated=%llu",
            m_Engine.MessagesProcessed(), m_Engine.IntentsCreated());
        m_Engine.Stop();

        UnregisterWorker();

        ShutdownSharedInfrastructure();
    }

private:
    ElleCognitiveEngine m_Engine;
};

int wmain(int argc, wchar_t* argv[])
{
    ElleCognitiveService svc;

    if (argc >= 2)
    {
        if (_wcsicmp(argv[1], L"install") == 0)
        {
            wchar_t exePath[MAX_PATH] = {};
            GetModuleFileNameW(nullptr, exePath, MAX_PATH);
            return svc.Install(L"Elle Cognitive Engine",
                L"Elle-Ann ESI — Intent parsing, NLP, attention threading, and self-prompt generation.",
                exePath) == ElleResult::OK ? 0 : 1;
        }
        else if (_wcsicmp(argv[1], L"uninstall") == 0)
            return svc.Uninstall() == ElleResult::OK ? 0 : 1;
        else if (_wcsicmp(argv[1], L"console") == 0) { svc.RunAsConsole(); return 0; }
    }

    // Double-click (no args) interactive install path
    if (argc == 1 && ElleServiceBase::IsInteractiveSession())
    {
        wchar_t exePath[MAX_PATH] = {};
        GetModuleFileNameW(nullptr, exePath, MAX_PATH);
        ElleResult r = svc.Install(L"Elle Cognitive Engine",
            L"Elle-Ann ESI — Intent parsing, NLP, attention threading, and self-prompt generation.",
            exePath);

        if (r == ElleResult::OK)
            MessageBoxW(nullptr, L"Service uploaded ok", L"Install", MB_OK | MB_ICONINFORMATION);
        else
            MessageBoxW(nullptr, L"Service upload failed", L"Install", MB_OK | MB_ICONERROR);

        return (r == ElleResult::OK) ? 0 : 1;
    }

    svc.RunAsService();
    return 0;
}
