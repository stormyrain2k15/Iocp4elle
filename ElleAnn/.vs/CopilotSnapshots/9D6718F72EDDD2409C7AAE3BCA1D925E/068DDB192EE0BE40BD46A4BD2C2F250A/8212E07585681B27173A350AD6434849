// =============================================================================
// Elle.Service.Memory — Service.cpp
//
// Manages Elle's short-term and long-term memory systems.
//
// What this service does:
//   - Maintains an in-process STM store (up to 256 items, 5-30s decay)
//   - Runs a recall loop every 30 seconds — pulls relevant LTM memories and
//     injects them back into active context via the IntentQueue
//   - Runs a consolidation loop every 5 minutes — promotes high-relevance
//     STM entries to LTM in ElleMemory.Memories
//   - Enforces a 1-hour cooldown between recalls of the same LTM memory
//   - Computes 3D spatial positions for new memories (x, y, z in memory map)
//   - Tags memories with their emotional weight from the Emotional engine
// =============================================================================

#include "../../Shared/ElleServiceBase.h"
#include "../../Shared/ElleEpoch.h"
#include "../../Shared/ElleSQLConn.h"
#include "../../Shared/ElleQueueIPC.h"
#include "../../Shared/ElleLogger.h"
#include "../../Shared/ElleConfig.h"
#include "../../Shared/ElleTypes.h"
#include <algorithm>
#include <vector>
#include <mutex>
#include <deque>
#include <cmath>
#include <random>

#define SVCNAME     ElleConfig::ServiceNames::MEMORY
#define LOG(lvl, fmt, ...) ELLE_LOG_##lvl(SVCNAME, fmt, ##__VA_ARGS__)

// =============================================================================
// STM entry — lives in process memory with a decay timer
// =============================================================================
struct STMEntry
{
    int64_t         ID;
    std::wstring    Content;
    std::wstring    Tags;
    double          RelevanceScore;
    double          EmotionalWeight;
    DWORD           ExpiryTickCount;    // GetTickCount() value when this entry expires
    bool            Promoted;           // Has been pushed to LTM
};

// =============================================================================
// ElleMemoryEngine
// =============================================================================
class ElleMemoryEngine
{
    ELLE_NONCOPYABLE(ElleMemoryEngine)
public:
    ElleMemoryEngine()
        : m_Running(false)
        , m_RecallThread(nullptr)
        , m_ConsolidateThread(nullptr)
        , m_STMDecayThread(nullptr)
        , m_StopEvent(nullptr)
        , m_NextSTMID(1)
        , m_RNG(std::random_device{}())
    {}

    ~ElleMemoryEngine() { Stop(); }

    ElleResult Start(HANDLE stopEvent)
    {
        LOG(INFO, L"ElleMemoryEngine starting. STMCapacity=%d RecallInterval=%dms",
            ElleConfig::Memory::STM_CAPACITY, ElleConfig::Memory::RECALL_INTERVAL_MS);
        m_StopEvent = stopEvent;
        m_Running = true;

        m_RecallThread = CreateThread(nullptr, 0, RecallThreadProc, this, 0, nullptr);
        m_ConsolidateThread = CreateThread(nullptr, 0, ConsolidateThreadProc, this, 0, nullptr);
        m_STMDecayThread = CreateThread(nullptr, 0, STMDecayThreadProc, this, 0, nullptr);

        if (!m_RecallThread || !m_ConsolidateThread || !m_STMDecayThread)
        {
            LOG(FATAL, L"CreateThread failed: %lu", GetLastError());
            m_Running = false;
            return ElleResult::ERR_GENERIC;
        }

        LOG(INFO, L"ElleMemoryEngine running");
        return ElleResult::OK;
    }

    void Stop()
    {
        if (!m_Running) return;
        LOG(INFO, L"ElleMemoryEngine stopping. STMSize=%zu", m_STMStore.size());
        m_Running = false;

        HANDLE threads[3] = { m_RecallThread, m_ConsolidateThread, m_STMDecayThread };
        WaitForMultipleObjects(3, threads, TRUE, 15000);
        ELLE_SAFE_CLOSE_HANDLE(m_RecallThread);
        ELLE_SAFE_CLOSE_HANDLE(m_ConsolidateThread);
        ELLE_SAFE_CLOSE_HANDLE(m_STMDecayThread);
        LOG(INFO, L"ElleMemoryEngine stopped");
    }

    // Add a new item to STM. Returns the STM ID.
    int64_t AddToSTM(const std::wstring& content, const std::wstring& tags, double relevance, double emotionalWeight)
    {
        std::lock_guard<std::mutex> lock(m_STMMutex);

        // Evict oldest if at capacity
        if ((int)m_STMStore.size() >= ElleConfig::Memory::STM_CAPACITY)
        {
            LOG(DEBUG, L"STM at capacity (%d) — evicting oldest entry", ElleConfig::Memory::STM_CAPACITY);
            m_STMStore.pop_front();
        }

        // Compute expiry time — scale decay duration by relevance
        DWORD decayRange = ElleConfig::Memory::STM_DECAY_MAX_MS - ElleConfig::Memory::STM_DECAY_MIN_MS;
        DWORD decayMs    = ElleConfig::Memory::STM_DECAY_MIN_MS + (DWORD)(decayRange * relevance);

        STMEntry entry;
        entry.ID                = m_NextSTMID++;
        entry.Content           = content;
        entry.Tags              = tags;
        entry.RelevanceScore    = relevance;
        entry.EmotionalWeight   = emotionalWeight;
        entry.ExpiryTickCount   = GetTickCount() + decayMs;
        entry.Promoted          = false;

        m_STMStore.push_back(entry);

        LOG(DEBUG, L"STM: Added ID=%lld decay=%dms relevance=%.2f STMSize=%zu",
            entry.ID, decayMs, relevance, m_STMStore.size());
        return entry.ID;
    }

    // Retrieve top N most relevant current STM entries
    std::vector<STMEntry> GetTopSTM(int count)
    {
        std::lock_guard<std::mutex> lock(m_STMMutex);
        std::vector<STMEntry> result;

        // Copy and sort by relevance
        std::vector<STMEntry> all(m_STMStore.begin(), m_STMStore.end());
        std::sort(all.begin(), all.end(),
            [](const STMEntry& a, const STMEntry& b) { return a.RelevanceScore > b.RelevanceScore; });

        int limit = std::min(count, (int)all.size());
        for (int i = 0; i < limit; i++)
            result.push_back(all[i]);

        return result;
    }

    uint64_t STMCount() const
    {
        std::lock_guard<std::mutex> lock(const_cast<std::mutex&>(m_STMMutex));
        return m_STMStore.size();
    }

private:
    // ==========================================================================
    // STM decay loop — removes expired entries and promotes high-relevance ones
    // ==========================================================================
    static DWORD WINAPI STMDecayThreadProc(LPVOID param)
    {
        auto* engine = static_cast<ElleMemoryEngine*>(param);
        LOG(INFO, L"STM decay loop running");

        while (engine->m_Running)
        {
            DWORD wait = WaitForSingleObject(engine->m_StopEvent, 1000);  // Check every 1s
            if (wait == WAIT_OBJECT_0) break;

            DWORD now = GetTickCount();
            std::lock_guard<std::mutex> lock(engine->m_STMMutex);

            int expired = 0, promoted = 0;
            auto it = engine->m_STMStore.begin();
            while (it != engine->m_STMStore.end())
            {
                if (now >= it->ExpiryTickCount)
                {
                    // Before evicting — check if it should be promoted to LTM
                    if (it->RelevanceScore >= ElleConfig::Memory::RELEVANCE_THRESHOLD && !it->Promoted)
                    {
                        engine->PromoteToLTM(*it);
                        promoted++;
                    }
                    LOG(TRACE, L"STM: Expiring ID=%lld content='%s' promoted=%d",
                        it->ID, it->Content.substr(0, 30).c_str(), it->Promoted ? 1 : 0);
                    it = engine->m_STMStore.erase(it);
                    expired++;
                }
                else
                {
                    ++it;
                }
            }

            if (expired > 0)
                LOG(DEBUG, L"STMDecay: Expired=%d Promoted=%d Remaining=%zu", expired, promoted, engine->m_STMStore.size());
        }

        LOG(INFO, L"STM decay loop exiting");
        return 0;
    }

    // ==========================================================================
    // Recall loop — surface relevant LTM memories every 30 seconds
    // ==========================================================================
    static DWORD WINAPI RecallThreadProc(LPVOID param)
    {
        auto* engine = static_cast<ElleMemoryEngine*>(param);
        LOG(INFO, L"Recall loop running. Interval=%dms CooldownSec=%d",
            ElleConfig::Memory::RECALL_INTERVAL_MS, ElleConfig::Memory::RECALL_COOLDOWN_SEC);

        while (engine->m_Running)
        {
            DWORD wait = WaitForSingleObject(engine->m_StopEvent, ElleConfig::Memory::RECALL_INTERVAL_MS);
            if (wait == WAIT_OBJECT_0) break;
            engine->RunRecallCycle();
        }

        LOG(INFO, L"Recall loop exiting");
        return 0;
    }

    void RunRecallCycle()
    {
        LOG(DEBUG, L"RunRecallCycle: Starting");

        ElleSQLScope memConn(ElleDB::MEMORY);
        if (!memConn.Valid())
        {
            LOG(ERROR, L"RunRecallCycle: DB unavailable");
            return;
        }

        // Select top N memories that haven't been recalled within cooldown
        std::vector<std::pair<int64_t, std::wstring>> recalled;

        memConn->Query(
            L"SELECT TOP " + std::to_wstring(ElleConfig::Memory::RECALL_RESULT_LIMIT) +
            L" MemoryID, Content FROM ElleMemory.dbo.Memories "
            L"WHERE Tier = 1 AND RelevanceScore >= " + std::to_wstring(ElleConfig::Memory::RELEVANCE_THRESHOLD) +
            L" AND DATEDIFF(SECOND, LastRecalled, GETDATE()) >= " + std::to_wstring(ElleConfig::Memory::RECALL_COOLDOWN_SEC) +
            L" ORDER BY RelevanceScore DESC, LastRecalled ASC",
            [&](const std::vector<std::wstring>& row)
            {
                if (row.size() >= 2)
                    recalled.push_back({ _wtoi64(row[0].c_str()), row[1] });
            }
        );

        if (recalled.empty())
        {
            LOG(DEBUG, L"RunRecallCycle: No eligible memories for recall");
            return;
        }

        LOG(INFO, L"RunRecallCycle: Recalling %zu memories", recalled.size());

        // Update LastRecalled for all selected memories
        for (auto& pair : recalled)
        {
            memConn->ExecuteParams(
                L"UPDATE ElleMemory.dbo.Memories SET LastRecalled = GETDATE(), RecallCount = RecallCount + 1 WHERE MemoryID = ?",
                { std::to_wstring(pair.first) }
            );

            // Also add to STM briefly so they're in active context
            AddToSTM(pair.second, L"recalled", ElleConfig::Memory::RELEVANCE_THRESHOLD, 0.3);

            LOG(DEBUG, L"RunRecallCycle: Recalled MemoryID=%lld", pair.first);
        }

        // Push a MEMORY_RECALL intent so the QueueWorker knows to surface these
        ElleSQLScope coreConn(ElleDB::CORE);
        if (coreConn.Valid())
        {
            coreConn->Execute(
                L"INSERT INTO ElleCore.dbo.IntentQueue (TypeID, StatusID, IntentData, TrustRequired, Priority, CreatedAt) "
                L"VALUES (5, 0, '{\"trigger\":\"auto_recall\"}', 0, 2, GETDATE())"
            );
        }
    }

    // ==========================================================================
    // Consolidation loop — promote STM to LTM every 5 minutes
    // ==========================================================================
    static DWORD WINAPI ConsolidateThreadProc(LPVOID param)
    {
        auto* engine = static_cast<ElleMemoryEngine*>(param);
        DWORD intervalMs = (DWORD)(ElleConfig::Memory::CONSOLIDATION_INTERVAL_SEC * 1000);
        LOG(INFO, L"Consolidation loop running. Interval=%ds", ElleConfig::Memory::CONSOLIDATION_INTERVAL_SEC);

        while (engine->m_Running)
        {
            DWORD wait = WaitForSingleObject(engine->m_StopEvent, intervalMs);
            if (wait == WAIT_OBJECT_0) break;
            engine->RunConsolidation();
        }

        LOG(INFO, L"Consolidation loop exiting");
        return 0;
    }

    void RunConsolidation()
    {
        LOG(DEBUG, L"RunConsolidation: Starting. STMSize=%zu", STMCount());

        std::lock_guard<std::mutex> lock(m_STMMutex);
        int promoted = 0;

        for (auto& entry : m_STMStore)
        {
            if (!entry.Promoted && entry.RelevanceScore >= ElleConfig::Memory::RELEVANCE_THRESHOLD)
            {
                PromoteToLTM(entry);
                promoted++;
            }
        }

        if (promoted > 0)
            LOG(INFO, L"RunConsolidation: Promoted %d STM entries to LTM", promoted);
        else
            LOG(DEBUG, L"RunConsolidation: No entries eligible for promotion");
    }

    // Promote one STM entry to LTM — must be called with appropriate conn
    void PromoteToLTM(STMEntry& entry)
    {
        ElleSQLScope memConn(ElleDB::MEMORY);
        if (!memConn.Valid())
        {
            LOG(ERROR, L"PromoteToLTM: DB unavailable for STM ID=%lld", entry.ID);
            return;
        }

        // Compute 3D position — use random placement within semantic clusters
        // A future version will use actual embedding similarity for placement
        std::uniform_real_distribution<float> dist(-100.0f, 100.0f);
        float posX = dist(m_RNG);
        float posY = dist(m_RNG);
        float posZ = dist(m_RNG);

        ElleResult r = memConn->ExecuteParams(
            L"INSERT INTO ElleMemory.dbo.Memories "
            L"(Content, Tags, Tier, RelevanceScore, EmotionalWeight, PosX, PosY, PosZ, CreatedAt, LastRecalled, RecallCount) "
            L"VALUES (?, ?, 1, ?, ?, ?, ?, ?, GETDATE(), GETDATE(), 0)",
            {
                entry.Content,
                entry.Tags,
                std::to_wstring(entry.RelevanceScore),
                std::to_wstring(entry.EmotionalWeight),
                std::to_wstring(posX),
                std::to_wstring(posY),
                std::to_wstring(posZ)
            }
        );

        if (r == ElleResult::OK)
        {
            entry.Promoted = true;
            LOG(INFO, L"PromoteToLTM: STM ID=%lld promoted to LTM. Pos=(%.1f,%.1f,%.1f) relevance=%.2f",
                entry.ID, posX, posY, posZ, entry.RelevanceScore);
        }
        else
        {
            LOG(ERROR, L"PromoteToLTM: DB write failed for STM ID=%lld: %s",
                entry.ID, memConn->LastError.c_str());
        }
    }

    std::deque<STMEntry>    m_STMStore;
    mutable std::mutex      m_STMMutex;

    HANDLE          m_RecallThread;
    HANDLE          m_ConsolidateThread;
    HANDLE          m_STMDecayThread;
    HANDLE          m_StopEvent;
    volatile bool   m_Running;
    int64_t         m_NextSTMID;
    std::mt19937    m_RNG;
};

// =============================================================================
// ElleMemoryService
// =============================================================================
class ElleMemoryService : public ElleServiceBase
{
public:
    ElleMemoryService() : ElleServiceBase(SVCNAME) {}

protected:
    ElleResult OnStart() override
    {
        LOG(INFO, L"OnStart: Initializing Memory service");

        ElleResult r = InitSharedInfrastructure();
        if (r != ElleResult::OK) return r;

        ElleEpochManager::Get().Init(false);

        RegisterWorker();

        r = m_Engine.Start(StopEvent());
        if (r != ElleResult::OK)
        {
            LOG(FATAL, L"MemoryEngine::Start() failed: %s", ElleResultStr(r));
            return r;
        }

        LOG(INFO, L"Memory service running");
        return ElleResult::OK;
    }

    void OnStop() override
    {
        LOG(INFO, L"OnStop: Stopping Memory service. STMCount=%llu", m_Engine.STMCount());
        m_Engine.Stop();

        UnregisterWorker();

        ShutdownSharedInfrastructure();
    }

private:
    ElleMemoryEngine m_Engine;
};

int wmain(int argc, wchar_t* argv[])
{
    ElleMemoryService svc;

    if (argc >= 2)
    {
        if (_wcsicmp(argv[1], L"install") == 0)
        {
            wchar_t exePath[MAX_PATH] = {};
            GetModuleFileNameW(nullptr, exePath, MAX_PATH);
            return svc.Install(L"Elle Memory Engine",
                L"Elle-Ann ESI — STM/LTM memory management, recall loops, and consolidation.",
                exePath) == ElleResult::OK ? 0 : 1;
        }
        else if (_wcsicmp(argv[1], L"uninstall") == 0)
            return svc.Uninstall() == ElleResult::OK ? 0 : 1;
        else if (_wcsicmp(argv[1], L"console") == 0) { svc.RunAsConsole(); return 0; }
    }

    // Double-click (no args) interactive install path
    if (argc == 1 && ElleServiceBase::IsInteractiveSession())
    {
        wchar_t exePath[MAX_PATH] = {};
        GetModuleFileNameW(nullptr, exePath, MAX_PATH);
        ElleResult r = svc.Install(L"Elle Memory Engine",
            L"Elle-Ann ESI — STM/LTM memory management, recall loops, and consolidation.",
            exePath);

        if (r == ElleResult::OK)
            MessageBoxW(nullptr, L"Service uploaded ok", L"Install", MB_OK | MB_ICONINFORMATION);
        else
            MessageBoxW(nullptr, L"Service upload failed", L"Install", MB_OK | MB_ICONERROR);

        return (r == ElleResult::OK) ? 0 : 1;
    }

    svc.RunAsService();
    return 0;
}
