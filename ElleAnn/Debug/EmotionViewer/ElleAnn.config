# ElleAnn.config — Runtime Configuration Override
# Location: C:\Elle\ElleAnn.config
# Format: KEY=VALUE, one per line
# Lines beginning with # are comments
# Values here override the defaults in ElleConfig.h at service startup
# All services read this file on Init. Edit without recompiling.
#
# ============================================================
# DATABASE
# ============================================================
DB_SERVER=DESKTOP-AD2OBAB\ELLEANN
DB_DRIVER={ODBC Driver 17 for SQL Server}

# Authentication mode: "windows" or "sql"
# windows = Trusted_Connection (service account needs SQL Server login)
# sql     = SQL Server login with username and password
#
# If your services run as LocalSystem, either:
#   A) Grant NT AUTHORITY\SYSTEM access in SQL Server (SSMS > Security > Logins)
#   B) Switch to SQL auth below
#
DB_AUTH=sql
DB_UID=sa
DB_PWD=Mitek2015
DB_POOL_MIN=2
DB_POOL_MAX=16
DB_CONNECT_TIMEOUT=10
DB_QUERY_TIMEOUT=30
DB_RETRY_COUNT=5
DB_RETRY_DELAY_MS=2000

# ============================================================
# QUEUE
# ============================================================
QUEUE_POLL_INTERVAL_MS=500
QUEUE_MAX_BATCH=10
QUEUE_INTENT_STALE_SEC=30
QUEUE_ACTION_RETAIN_SEC=60
QUEUE_MAX_WORKERS=4

# ============================================================
# NETWORK (HTTP + WebSocket)
# ============================================================
HTTP_PORT=8000
WS_MAX_CLIENTS=32
HTTP_KEEPALIVE_SEC=30
WS_PING_INTERVAL_SEC=15
WS_TIMEOUT_SEC=60

# ============================================================
# EMOTIONAL ENGINE
# ============================================================
EMOTION_DECAY_RATE=0.05
EMOTION_DECAY_TICK_MS=1000
EMOTION_CONTAGION_WEIGHT=0.15
EMOTION_PERSIST_INTERVAL_SEC=5

# ============================================================
# MEMORY
# ============================================================
MEMORY_STM_CAPACITY=256
MEMORY_RECALL_INTERVAL_MS=30000
MEMORY_RECALL_COOLDOWN_SEC=3600
MEMORY_CONSOLIDATION_SEC=300
MEMORY_RECALL_LIMIT=5
MEMORY_RELEVANCE_THRESHOLD=0.4

# ============================================================
# TRUST
# ============================================================
TRUST_SUCCESS_REWARD=2
TRUST_FAILURE_PENALTY=3

# ============================================================
# HEARTBEAT
# ============================================================
HEARTBEAT_PING_INTERVAL_MS=5000
HEARTBEAT_WATCHDOG_CHECK_MS=10000
HEARTBEAT_STALE_TIMEOUT_SEC=60
HEARTBEAT_DEAD_MAN_SEC=300
HEARTBEAT_BIOMETRIC_TIMEOUT_SEC=120

# ============================================================
# LOGGING
# Set LOG_LEVEL to: 0=TRACE 1=DEBUG 2=INFO 3=WARN 4=ERROR 5=FATAL
# LOG_TARGETS is a bitmask: 1=FILE 2=SQL 4=DEBUGGER 8=CONSOLE
# Default: FILE+SQL (3), TRACE level (0) — log everything
# ============================================================
LOG_LEVEL=0
LOG_TARGETS=3
LOG_DIR=C:\Elle\Logs\
LOG_MAX_FILE_MB=50
LOG_MAX_ROTATED=10

# ============================================================
# LUA
# ============================================================
LUA_SCRIPT_DIR=C:\Elle\Lua\scripts\
LUA_HOT_RELOAD_MS=5000
